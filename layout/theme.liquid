<!doctype html>
<html
  {% if request.design_mode %}
    class="shopify-design-mode"
  {% endif %}
  lang="{{ request.locale.iso_code }}"
>
  <head>
    {%- if settings.favicon != blank -%}
      <link
        rel="icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: 32, height: 32 }}"
      >
    {%- endif -%}

    {% comment %} This a way to wait for main content to load when navigating to a new page so that the view transitions can work consistently {% endcomment %}
    {% if settings.transition_to_main_product or settings.page_transition_enabled %}
      <link
        rel="expect"
        href="#MainContent"
        blocking="render"
        id="view-transition-render-blocker"
      >
    {% endif %}

    {%- render 'meta-tags' -%}
    {%- render 'stylesheets' -%}
    {%- render 'fonts' -%}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Chewy&family=Lora:ital,wght@0,400;0,700;1,400;1,700&family=DM+Sans:wght@400;500;600&family=DM+Serif+Display:ital,wght@0,400;1,400&family=Montserrat:wght@400;500;600&family=Poppins:wght@300;400;500;600&family=Quicksand:wght@400;500;600&display=swap" rel="stylesheet">
    {%- render 'scripts' -%}
    {%- render 'theme-styles-variables' -%}
    {%- render 'color-schemes' -%}

    {% if request.design_mode %}
      {%- render 'theme-editor' -%}
    {% endif %}

    {{ content_for_header }}

    <style>
      /* Global font overrides */
      body {
        font-family: 'Poppins', sans-serif !important;
      }

      /* Hero line 1 - "Seal in the fun," */
      [class*="text_bnhyzU"] h1 {
        font-family: 'Chewy', cursive !important;
        font-weight: normal !important;
        color: #000000 !important;
        font-size: 3.375rem !important;
        margin-bottom: 0 !important;
        line-height: 1.1 !important;
      }

      /* Hero line 2 - "enjoy it NauNau" */
      [class*="text_bnhyzU"] h2 {
        font-family: 'Chewy', cursive !important;
        font-weight: normal !important;
        color: #000000 !important;
        font-size: 3.375rem !important;
        margin-top: 0.15rem !important;
        margin-bottom: 0 !important;
        line-height: 1.1 !important;
      }

      /* NauNau brand name - bigger + maroon + bolder */
      [class*="text_bnhyzU"] h2 strong {
        color: #731a47 !important;
        font-family: 'Chewy', cursive !important;
        font-size: 4.2rem !important;
        font-weight: bold !important;
        letter-spacing: 0.02em !important;
      }

      /* Hero subtitle line 1 - Montserrat, olive green, bold */
      [class*="text_bnhyzU"] p {
        font-family: 'Montserrat', sans-serif !important;
        font-size: 1.125rem !important;
        font-weight: 600 !important;
        color: #556B2F !important;
        letter-spacing: 0.05em !important;
        text-transform: uppercase !important;
        margin-top: 0.5rem !important;
      }

      /* Hero subtitle line 2 - Quicksand, black, bold */
      [class*="text_bnhyzU"] p + p {
        font-family: 'Quicksand', sans-serif !important;
        text-transform: none !important;
        font-style: italic !important;
        font-size: 1rem !important;
        font-weight: 600 !important;
        letter-spacing: normal !important;
        color: #000000 !important;
      }
      /* Why You'll Love It - card headings in Chewy */
      [class*="text_planetTitle"] h3,
      [class*="text_leakTitle"] h3,
      [class*="text_tempTitle"] h3,
      [class*="text_endlessTitle"] h3 {
        font-family: 'Chewy', cursive !important;
        font-weight: normal !important;
        font-size: 1.5rem !important;
        line-height: 1.3 !important;
      }

      /* Why You'll Love It - section heading in Chewy */
      [class*="text_whyHeading"] h2 {
        font-family: 'Chewy', cursive !important;
        font-weight: normal !important;
      }

      /* Product media - rounded corners */
      .product-media-container,
      .product-media-container img,
      .product-media-container model-viewer,
      .product-media-container video,
      .product-media-container iframe,
      media-gallery .product-media {
        border-radius: 10px !important;
        overflow: hidden;
      }

      /* Product page title - Chewy font, bigger */
      .product-information h1,
      [class*="text_rmfzht"] h1 {
        font-family: 'Chewy', cursive !important;
        font-weight: normal !important;
        font-size: 2.2rem !important;
        line-height: 1.2 !important;
      }

      /* Hide account icon in header */
      .account-popover,
      .account-drawer-trigger {
        display: none !important;
      }

      /* Autoplay videos: hide controls & prevent black bar */
      deferred-media[autoplay] video {
        object-fit: cover;
      }
      deferred-media[autoplay] video::-webkit-media-controls {
        display: none !important;
      }

      /* Shrink header on scroll */
      .header[data-sticky-state='active'] {
        --header-height: 45px !important;
        transition: all 0.3s ease !important;
      }

      .header[data-sticky-state='active'] .header__logo img,
      .header[data-sticky-state='active'] .header__logo svg {
        max-height: 35px !important;
        transition: max-height 0.3s ease !important;
      }

      .header[data-sticky-state='active'] .header__row {
        padding-block: 2px !important;
      }

      /* Smooth transition back when scrolling to top */
      .header {
        transition: all 0.3s ease !important;
      }

      .header .header__logo img,
      .header .header__logo svg {
        transition: max-height 0.3s ease !important;
      }
      /* Front cover: center with max-width, no gap between text and video */
      [id*="section_E9C4Fd"] .section-content-wrapper {
        max-width: 1000px !important;
        margin-left: auto !important;
        margin-right: auto !important;
        gap: 0px !important;
      }

      /* Hero heading styles */
      [id*="section_E9C4Fd"] h1 {
        font-family: 'Lora', serif !important;
        font-weight: 900 !important;
        line-height: 1.1 !important;
        margin: 0 !important;
        color: #000000 !important;
        text-transform: none !important;
        letter-spacing: -0.02em !important;
      }

      /* Second h1 = same black color */
      [id*="section_E9C4Fd"] h1 + h1 {
        color: #000000 !important;
      }

      /* Underline on "ever buy" in maroon */
      [id*="section_E9C4Fd"] h1 span[style*="underline"],
      [id*="section_E9C4Fd"] h1 u {
        text-decoration: underline !important;
        text-decoration-color: #731a47 !important;
        text-underline-offset: 8px !important;
        text-decoration-thickness: 4px !important;
      }

      /* Subtitle text */
      [id*="section_E9C4Fd"] h4 {
        font-family: 'Lora', serif !important;
        font-weight: 400 !important;
        color: #555555 !important;
        text-transform: none !important;
        letter-spacing: normal !important;
      }

      [id*="section_E9C4Fd"] .text-block p {
        color: #666666 !important;
        text-transform: none !important;
        letter-spacing: normal !important;
      }

      /* Front cover spacing between blocks */
      [id*="section_E9C4Fd"] .group-block-content {
        gap: 0px !important;
      }
      [id*="section_E9C4Fd"] [class*="text_bYcxaA"] {
        margin-top: 25px !important;
      }
      [id*="section_E9C4Fd"] [class*="text_9hhcEt"] {
        margin-top: 14px !important;
      }
      [id*="section_E9C4Fd"] .group-block-content > .group-block {
        margin-top: 30px !important;
      }
      [id*="section_E9C4Fd"] .group-block-content > .group-block .group-block-content {
        gap: 20px !important;
      }

      /* Animated strikethrough */
      .naunau-strikethrough {
        position: relative;
        color: #555555;
      }
      .naunau-strikethrough::after {
        content: '';
        position: absolute;
        left: 0;
        top: 50%;
        height: 3px;
        background: #731a47;
        width: 0;
        transition: width 0.8s ease;
      }
      .naunau-strikethrough.animate::after {
        width: 100%;
      }

      @media screen and (max-width: 749px) {
        [id*="section_E9C4Fd"] h1 {
          font-size: 2.2rem !important;
        }
      }
    </style>
    <script>
      document.addEventListener('DOMContentLoaded', function() {
        // NauNau in Chewy font in hero heading
        var headings = document.querySelectorAll('[id*="section_E9C4Fd"] h1');
        headings.forEach(function(h) {
          if (h.textContent.includes('NauNau')) {
            h.innerHTML = h.innerHTML.replace(/NauNau/g, '<span style="font-family:\'Chewy\',cursive;font-weight:normal;font-style:normal;font-size:1.3em">NauNau</span>');
          }
        });
        // Animated strikethrough "Plastic" in purple
        var subheadings = document.querySelectorAll('[id*="section_E9C4Fd"] h4');
        subheadings.forEach(function(h) {
          if (h.textContent.includes('Plastic')) {
            h.innerHTML = h.innerHTML.replace(/Plastic/g, '<span class="naunau-strikethrough">Plastic</span>');
          }
        });
        // Trigger animation when visible
        var strikeEl = document.querySelector('.naunau-strikethrough');
        if (strikeEl) {
          var obs = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('animate');
                obs.unobserve(entry.target);
              }
            });
          }, { threshold: 0.5 });
          obs.observe(strikeEl);
        }
      });
    </script>
    {% render 'naunau-custom-css' %}
  </head>

  <body class="page-width-{{ settings.page_width }} card-hover-effect-{{ settings.card_hover_effect }}">
    {% render 'skip-to-content-link', href: '#MainContent', text: 'accessibility.skip_to_text' %}
    <div id="header-group">
      {% sections 'header-group' %}
    </div>

    <script>
      // Inline header height and menu style calculations to prevent layout shift
      // Note: Updates in calculateHeaderGroupHeight(), updateTransparentHeaderOffset() and setHeaderMenuStyle() utilities.js should be kept in sync with this function
      (function setHeaderHeighCustomProperties() {
        /*
         * Header calculation functions for maintaining CSS variables
         * Mimic calculateHeaderGroupHeight() in utilities.js
         */
        const header = document.querySelector('header-component');
        const headerGroup = document.querySelector('#header-group');
        const hasHeaderSection = headerGroup?.querySelector('.header-section');

        if (!header || !headerGroup) return;

        const headerHeight = header.offsetHeight;

        // Calculate the total height of the header group
        let headerGroupHeight = 0;
        const children = headerGroup.children;
        for (let i = 0; i < children.length; i++) {
          const element = children[i];
          if (element === header || !(element instanceof HTMLElement)) continue;
          headerGroupHeight += element.offsetHeight;
        }

        // Check for transparent header special case
        if (header.hasAttribute('transparent') && header.parentElement?.nextElementSibling) {
          headerGroupHeight += headerHeight;
        }

        // Set CSS variables
        document.body.style.setProperty('--header-height', `${headerHeight}px`);
        document.body.style.setProperty('--header-group-height', `${headerGroupHeight}px`);

        /**
         * Updates CSS custom properties for transparent header offset calculation
         * Mimic updateTransparentHeaderOffset() in utilities.js
         */

        if (!hasHeaderSection || !header?.hasAttribute('transparent')) {
          document.body.style.setProperty('--transparent-header-offset-boolean', '0');
          return;
        }

        const hasImmediateSection = hasHeaderSection.nextElementSibling?.classList.contains('shopify-section');

        const shouldApplyOffset = !hasImmediateSection ? '1' : '0';
        document.body.style.setProperty('--transparent-header-offset-boolean', shouldApplyOffset);
      })();

      (function setHeaderMenuStyle() {
        const headerComponent = document.querySelector('#header-component');
        if (headerComponent) {
          const isTouchDevice = 'ontouchstart' in window && navigator.maxTouchPoints > 0;
          const overflowList = headerComponent?.querySelector('overflow-list');
          const hasReachedMinimum = overflowList && overflowList.hasAttribute('minimum-reached');
          headerComponent.dataset.menuStyle = isTouchDevice || hasReachedMinimum ? 'drawer' : 'menu';
        }
      })();
    </script>

    <main
      id="MainContent"
      class="content-for-layout"
      role="main"
      data-page-transition-enabled="{{ settings.page_transition_enabled }}"
      data-product-transition="{{ settings.transition_to_main_product }}"
      data-template="{{ template }}"
    >
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}

    {% render 'search-modal' %}

    {% if settings.quick_add or settings.mobile_quick_add %}
      {% render 'quick-add-modal' %}
    {% endif %}
  </body>
</html>
