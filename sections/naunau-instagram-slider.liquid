<style>
  .insta-slider-section {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
  }
  .insta-slider-heading {
    text-align: center;
    font-family: '{{ section.settings.heading_font }}', cursive;
    font-size: {{ section.settings.heading_size }}px;
    color: {{ section.settings.heading_color }};
    margin-bottom: {{ section.settings.heading_spacing }}px;
  }
  .insta-slider-wrapper {
    width: {{ section.settings.slider_width }}%;
    overflow: hidden;
    position: relative;
    margin: auto;
  }
  .insta-slider-carousel {
    display: flex;
    transition: transform 0.5s ease-in-out;
    user-select: none;
  }
  .insta-slider-slide {
    flex: 0 0 auto;
    overflow: hidden;
    margin-right: {{ section.settings.slide_gap }}px;
    width: {{ section.settings.slide_width }}px;
    height: {{ section.settings.slide_height }}px;
    border-radius: {{ section.settings.slide_radius }}px;
  }
  .insta-slider-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: {{ section.settings.slide_radius }}px;
    display: block;
  }
  .insta-slider-controls {
    display: flex;
    justify-content: center;
    margin-top: 15px;
    gap: 15px;
  }
  .insta-slider-prev,
  .insta-slider-next {
    font-size: 24px;
    cursor: pointer;
    color: {{ section.settings.arrow_color }};
    padding: 5px 10px;
    transition: opacity 0.2s;
  }
  .insta-slider-prev:hover,
  .insta-slider-next:hover {
    opacity: 0.7;
  }

  @media (max-width: 768px) {
    .insta-slider-wrapper {
      width: 95%;
    }
    .insta-slider-slide {
      width: {{ section.settings.slide_width | divided_by: 1.5 | round }}px;
      height: {{ section.settings.slide_height | divided_by: 1.5 | round }}px;
    }
    .insta-slider-heading {
      font-size: {{ section.settings.heading_size | minus: 8 }}px;
    }
  }
</style>

{% if section.settings.heading != blank %}
  <div class="insta-slider-heading">{{ section.settings.heading }}</div>
{% endif %}

<div class="insta-slider-section">
  <div class="insta-slider-wrapper" id="insta-slider-{{ section.id }}">
    <div class="insta-slider-carousel">
      {% for block in section.blocks %}
        {% if block.settings.image != blank %}
          <a class="insta-slider-slide" href="{{ block.settings.link | default: '#' }}" target="_blank" {{ block.shopify_attributes }}>
            <img src="{{ block.settings.image | image_url: width: 500 }}" alt="{{ block.settings.alt_text | default: 'Instagram post' }}" loading="lazy">
          </a>
        {% endif %}
      {% endfor %}
    </div>
    <div class="insta-slider-controls">
      <div class="insta-slider-prev" data-slider="{{ section.id }}">&#10094;</div>
      <div class="insta-slider-next" data-slider="{{ section.id }}">&#10095;</div>
    </div>
  </div>
</div>

<script>
  (function() {
    const wrapper = document.getElementById('insta-slider-{{ section.id }}');
    if (!wrapper) return;

    const slider = wrapper.querySelector('.insta-slider-carousel');
    const slides = wrapper.querySelectorAll('.insta-slider-slide');
    if (slides.length === 0) return;

    const gap = {{ section.settings.slide_gap }};
    const speed = {{ section.settings.auto_speed }};
    const slideWidth = slides[0].offsetWidth + gap;
    const totalSlides = slides.length;
    let currentIndex = 0;
    let isTransitioning = false;

    // Clone all slides for seamless loop
    slides.forEach(function(slide) {
      const clone = slide.cloneNode(true);
      clone.classList.add('clone');
      slider.appendChild(clone);
    });

    function goTo(index, animate) {
      if (isTransitioning) return;
      isTransitioning = true;
      currentIndex = index;

      if (animate) {
        slider.style.transition = 'transform 0.5s ease-in-out';
      } else {
        slider.style.transition = 'none';
      }
      slider.style.transform = 'translateX(' + (-currentIndex * slideWidth) + 'px)';

      if (animate) {
        setTimeout(function() {
          if (currentIndex >= totalSlides) {
            slider.style.transition = 'none';
            currentIndex = 0;
            slider.style.transform = 'translateX(0px)';
          } else if (currentIndex < 0) {
            slider.style.transition = 'none';
            currentIndex = totalSlides - 1;
            slider.style.transform = 'translateX(' + (-currentIndex * slideWidth) + 'px)';
          }
          isTransitioning = false;
        }, 520);
      } else {
        isTransitioning = false;
      }
    }

    function moveForward() {
      goTo(currentIndex + 1, true);
    }

    // Auto-scroll
    let autoInterval = null;
    {% if section.settings.auto_scroll %}
      autoInterval = setInterval(moveForward, speed);
    {% endif %}

    function resetAuto() {
      if (autoInterval) clearInterval(autoInterval);
      {% if section.settings.auto_scroll %}
        autoInterval = setInterval(moveForward, speed);
      {% endif %}
    }

    // Controls
    wrapper.querySelector('.insta-slider-prev').addEventListener('click', function() {
      resetAuto();
      goTo(currentIndex - 1, true);
    });
    wrapper.querySelector('.insta-slider-next').addEventListener('click', function() {
      resetAuto();
      goTo(currentIndex + 1, true);
    });

    // Touch/swipe support
    let touchStartX = 0;
    let touchEndX = 0;
    wrapper.addEventListener('touchstart', function(e) {
      touchStartX = e.changedTouches[0].screenX;
    }, { passive: true });
    wrapper.addEventListener('touchend', function(e) {
      touchEndX = e.changedTouches[0].screenX;
      const diff = touchStartX - touchEndX;
      if (Math.abs(diff) > 50) {
        resetAuto();
        if (diff > 0) {
          goTo(currentIndex + 1, true);
        } else {
          goTo(currentIndex - 1, true);
        }
      }
    }, { passive: true });
  })();
</script>

{% schema %}
{
  "name": "Instagram Slider",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Follow Us on Instagram"
    },
    {
      "type": "select",
      "id": "heading_font",
      "label": "Heading font",
      "options": [
        { "value": "Chewy", "label": "Chewy" },
        { "value": "Playfair Display", "label": "Playfair Display" },
        { "value": "Arial", "label": "Arial" },
        { "value": "Georgia", "label": "Georgia" }
      ],
      "default": "Chewy"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 16,
      "max": 60,
      "step": 2,
      "default": 32,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#333333"
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "label": "Space below heading",
      "min": 0,
      "max": 60,
      "step": 5,
      "default": 20,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "slider_width",
      "label": "Slider width",
      "min": 50,
      "max": 100,
      "step": 5,
      "default": 80,
      "unit": "%"
    },
    {
      "type": "range",
      "id": "slide_width",
      "label": "Slide width",
      "min": 100,
      "max": 400,
      "step": 10,
      "default": 200,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "slide_height",
      "label": "Slide height",
      "min": 100,
      "max": 500,
      "step": 10,
      "default": 250,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "slide_gap",
      "label": "Gap between slides",
      "min": 0,
      "max": 40,
      "step": 5,
      "default": 20,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "slide_radius",
      "label": "Slide corner radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "default": 10,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "arrow_color",
      "label": "Arrow color",
      "default": "#CDCDCD"
    },
    {
      "type": "checkbox",
      "id": "auto_scroll",
      "label": "Auto-scroll",
      "default": true
    },
    {
      "type": "range",
      "id": "auto_speed",
      "label": "Auto-scroll speed",
      "min": 1000,
      "max": 5000,
      "step": 500,
      "default": 2000,
      "unit": "ms"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 40,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (Instagram URL)"
        },
        {
          "type": "text",
          "id": "alt_text",
          "label": "Alt text",
          "default": "Instagram post"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Instagram Slider",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
