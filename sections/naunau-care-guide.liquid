        { "type": "quick_win", "settings": { "icon": "🌿", "text": "100% food-grade silicone" } },
        { "type": "callout_section", "settings": { "emoji": "🧼", "tag": "Everyday Care", "title": "Washing your NauNau bags", "intro": "Good news — cleaning your NauNau is genuinely easy. Two options, zero stress.", "box1_icon": "✅", "box1_title": "Dishwasher? Go for it.", "box1_text": "Chuck them on any rack — top or bottom, NauNau doesn't mind. Just skip the inside-out flip (more on that below).", "box1_style": "sage", "box2_icon": "🚿", "box2_title": "Hand washing works great too.", "box2_text": "Warm, soapy water + a bottle brush for the corners = squeaky clean. Done.", "box2_style": "cream" } },
        { "type": "callout_section", "settings": { "emoji": "🙅", "tag": "The Golden Rule", "title": "Please don't flip them inside out", "intro": "We know it's tempting — it looks just like a plastic bag. But resist! Here's why it matters:", "box1_icon": "⚠️", "box1_title": "The edges are the secret sauce.", "box1_text": "Your NauNau's sealed edges are bonded with pure platinum food-grade silicone, then cured for strength. Flipping inside out stresses those seams and can cause tears over time. Treat those edges like the precious things they are.", "box1_style": "terracotta" } },
        { "type": "steps_section", "settings": { "emoji": "🧅", "tag": "Freshening Up", "title": "Banishing stubborn smells", "intro": "Silicone is naturally odour-resistant, but onions and garlic have a way of making themselves at home. Here's how to evict them:", "step1": "<strong>The vinegar soak.</strong> Mix equal parts warm water and white vinegar, then let your bag soak for a few hours. Simple, effective, and very satisfying.", "step2": "<strong>The oven trick.</strong> Pop it on a baking sheet and bake for 8 minutes at 180°C (350°F). Use oven mitts — silicone holds heat! Let it cool completely before touching.", "step3": "<strong>For serious offenders (looking at you, kimchi):</strong> Do both. Vinegar soak first, then a quick bake. Your bag will come out smelling like nothing at all — which is exactly the goal." } },
        { "type": "callout_section", "settings": { "emoji": "☀️", "tag": "Natural Magic", "title": "Getting rid of stains", "intro": "This one never gets old — sunlight is NauNau's best friend.", "box1_icon": "✨", "box1_title": "Leave it in the sun for a few hours.", "box1_text": "UV light naturally bleaches out stains — no harsh chemicals needed. Tomato sauce, carrot, watermelon, beetroot... sunlight handles them all. Just set your bag on the windowsill or outside and let nature do its thing. It genuinely works like magic.", "box1_style": "sage" } },
        { "type": "tips_section", "settings": { "emoji": "🌿", "tag": "Prevention is Everything", "title": "Keeping mold away", "intro": "Mold needs two things: food particles and moisture. Take those away and it has nowhere to go.", "tip1": "Rinse out food residue after every use — a quick rinse is all it takes.", "tip2": "A bottle brush is brilliant for getting into the corners properly.", "tip3": "For extra peace of mind, give your bag a quick soak in white vinegar or a dip in boiling water. Either one sanitises beautifully." } },
        { "type": "tips_section", "settings": { "emoji": "💨", "tag": "After the Wash", "title": "Drying your bags properly", "intro": "Silicone is a bit of a water collector — give it the time it needs to dry fully.", "tip1": "Stand bags upright over a bottle, cup, or paper towel holder so air can circulate inside. Works a treat.", "tip2": "A drying rack (bamboo or otherwise) is your best friend here — bags can hang open and dry thoroughly.", "tip3": "Air drying might leave harmless water spots. If that bothers you, just wipe down with a clean cloth before storing." } },
        { "type": "tips_section", "settings": { "emoji": "🗄️", "tag": "Between Uses", "title": "Storing your NauNau bags", "intro": "A little thought about storage keeps your bags in perfect shape.", "tip1": "Always store bags with the seal open — this lets moisture escape and prevents any build-up inside.", "tip2": "Flat in a drawer or stacked in a basket both work well. They're flexible, literally." } },
