<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

<div class="naunau-care">

  {%- comment -%} ─── HERO ─── {%- endcomment -%}
  <div class="nc-hero" style="background-color: {{ section.settings.hero_bg }};">
    <p class="nc-hero-eyebrow nc-animate" style="color: {{ section.settings.hero_eyebrow_color }};">{{ section.settings.hero_eyebrow }}</p>
    <h1 class="nc-animate nc-delay-1" style="color: {{ section.settings.hero_heading_color }};">{{ section.settings.hero_line1 }}<br><em style="color: {{ section.settings.hero_italic_color }};">{{ section.settings.hero_line2 }}</em></h1>
    <p class="nc-hero-sub nc-animate nc-delay-2" style="color: {{ section.settings.hero_sub_color }};">{{ section.settings.hero_sub }}</p>
  </div>

  {%- comment -%} ─── QUICK WINS ─── {%- endcomment -%}
  <div class="nc-quick-wins" style="background: {{ section.settings.wins_bg }};">
    {%- for block in section.blocks -%}
      {%- if block.type == 'quick_win' -%}
        <div class="nc-quick-win" style="color: {{ section.settings.wins_text_color }};" {{ block.shopify_attributes }}>
          <span class="nc-icon">{{ block.settings.icon }}</span> {{ block.settings.text }}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>

  <div class="nc-container">
    {%- for block in section.blocks -%}

      {%- comment -%} ─── CALLOUT SECTION ─── {%- endcomment -%}
      {%- if block.type == 'callout_section' -%}
        <div class="nc-section" {{ block.shopify_attributes }}>
          <div class="nc-section-header">
            <div class="nc-section-emoji">{{ block.settings.emoji }}</div>
            <div class="nc-section-title-wrap">
              <p class="nc-section-tag" style="color: {{ section.settings.tag_color }};">{{ block.settings.tag }}</p>
              <h2 class="nc-section-title" style="color: {{ section.settings.title_color }};">{{ block.settings.title }}</h2>
            </div>
          </div>
          {%- if block.settings.intro != blank -%}
            <p class="nc-section-intro" style="color: {{ section.settings.intro_color }};">{{ block.settings.intro }}</p>
          {%- endif -%}
          {%- if block.settings.box1_title != blank -%}
            <div class="nc-callout nc-{{ block.settings.box1_style }}">
              <div class="nc-callout-icon">{{ block.settings.box1_icon }}</div>
              <div class="nc-callout-body">
                <p class="nc-callout-title">{{ block.settings.box1_title }}</p>
                <p class="nc-callout-text">{{ block.settings.box1_text }}</p>
              </div>
            </div>
          {%- endif -%}
          {%- if block.settings.box2_title != blank -%}
            <div class="nc-callout nc-{{ block.settings.box2_style }}">
              <div class="nc-callout-icon">{{ block.settings.box2_icon }}</div>
              <div class="nc-callout-body">
                <p class="nc-callout-title">{{ block.settings.box2_title }}</p>
                <p class="nc-callout-text">{{ block.settings.box2_text }}</p>
              </div>
            </div>
          {%- endif -%}
        </div>

      {%- comment -%} ─── STEPS SECTION ─── {%- endcomment -%}
      {%- elsif block.type == 'steps_section' -%}
        <div class="nc-section" {{ block.shopify_attributes }}>
          <div class="nc-section-header">
            <div class="nc-section-emoji">{{ block.settings.emoji }}</div>
            <div class="nc-section-title-wrap">
              <p class="nc-section-tag" style="color: {{ section.settings.tag_color }};">{{ block.settings.tag }}</p>
              <h2 class="nc-section-title" style="color: {{ section.settings.title_color }};">{{ block.settings.title }}</h2>
            </div>
          </div>
          {%- if block.settings.intro != blank -%}
            <p class="nc-section-intro" style="color: {{ section.settings.intro_color }};">{{ block.settings.intro }}</p>
          {%- endif -%}
          <div class="nc-steps">
            {%- if block.settings.step1 != blank -%}
              <div class="nc-step">
                <div class="nc-step-num" style="background: {{ section.settings.accent_color }};">1</div>
                <div class="nc-step-text">{{ block.settings.step1 }}</div>
              </div>
            {%- endif -%}
            {%- if block.settings.step2 != blank -%}
              <div class="nc-step">
                <div class="nc-step-num" style="background: {{ section.settings.accent_color }};">2</div>
                <div class="nc-step-text">{{ block.settings.step2 }}</div>
              </div>
            {%- endif -%}
            {%- if block.settings.step3 != blank -%}
              <div class="nc-step">
                <div class="nc-step-num" style="background: {{ section.settings.accent_color }};">3</div>
                <div class="nc-step-text">{{ block.settings.step3 }}</div>
              </div>
            {%- endif -%}
            {%- if block.settings.step4 != blank -%}
              <div class="nc-step">
                <div class="nc-step-num" style="background: {{ section.settings.accent_color }};">4</div>
                <div class="nc-step-text">{{ block.settings.step4 }}</div>
              </div>
            {%- endif -%}
            {%- if block.settings.step5 != blank -%}
              <div class="nc-step">
                <div class="nc-step-num" style="background: {{ section.settings.accent_color }};">5</div>
                <div class="nc-step-text">{{ block.settings.step5 }}</div>
              </div>
            {%- endif -%}
          </div>
        </div>

      {%- comment -%} ─── TIPS SECTION ─── {%- endcomment -%}
      {%- elsif block.type == 'tips_section' -%}
        <div class="nc-section" {{ block.shopify_attributes }}>
          <div class="nc-section-header">
            <div class="nc-section-emoji">{{ block.settings.emoji }}</div>
            <div class="nc-section-title-wrap">
              <p class="nc-section-tag" style="color: {{ section.settings.tag_color }};">{{ block.settings.tag }}</p>
              <h2 class="nc-section-title" style="color: {{ section.settings.title_color }};">{{ block.settings.title }}</h2>
            </div>
          </div>
          {%- if block.settings.intro != blank -%}
            <p class="nc-section-intro" style="color: {{ section.settings.intro_color }};">{{ block.settings.intro }}</p>
          {%- endif -%}
          <ul class="nc-tips-list">
            {%- if block.settings.tip1 != blank -%}<li>{{ block.settings.tip1 }}</li>{%- endif -%}
            {%- if block.settings.tip2 != blank -%}<li>{{ block.settings.tip2 }}</li>{%- endif -%}
            {%- if block.settings.tip3 != blank -%}<li>{{ block.settings.tip3 }}</li>{%- endif -%}
            {%- if block.settings.tip4 != blank -%}<li>{{ block.settings.tip4 }}</li>{%- endif -%}
            {%- if block.settings.tip5 != blank -%}<li>{{ block.settings.tip5 }}</li>{%- endif -%}
          </ul>
        </div>

      {%- comment -%} ─── DO / DON'T SECTION ─── {%- endcomment -%}
      {%- elsif block.type == 'dodont_section' -%}
        <div class="nc-section" {{ block.shopify_attributes }}>
          <div class="nc-section-header">
            <div class="nc-section-emoji">{{ block.settings.emoji }}</div>
            <div class="nc-section-title-wrap">
              <p class="nc-section-tag" style="color: {{ section.settings.tag_color }};">{{ block.settings.tag }}</p>
              <h2 class="nc-section-title" style="color: {{ section.settings.title_color }};">{{ block.settings.title }}</h2>
            </div>
          </div>
          <div class="nc-do-dont">
            <div class="nc-do-card">
              <p class="nc-card-label">{{ block.settings.do_label }}</p>
              {%- if block.settings.do1 != blank -%}<div class="nc-card-item"><div class="nc-dot"></div>{{ block.settings.do1 }}</div>{%- endif -%}
              {%- if block.settings.do2 != blank -%}<div class="nc-card-item"><div class="nc-dot"></div>{{ block.settings.do2 }}</div>{%- endif -%}
              {%- if block.settings.do3 != blank -%}<div class="nc-card-item"><div class="nc-dot"></div>{{ block.settings.do3 }}</div>{%- endif -%}
              {%- if block.settings.do4 != blank -%}<div class="nc-card-item"><div class="nc-dot"></div>{{ block.settings.do4 }}</div>{%- endif -%}
              {%- if block.settings.do5 != blank -%}<div class="nc-card-item"><div class="nc-dot"></div>{{ block.settings.do5 }}</div>{%- endif -%}
              {%- if block.settings.do6 != blank -%}<div class="nc-card-item"><div class="nc-dot"></div>{{ block.settings.do6 }}</div>{%- endif -%}
            </div>
            <div class="nc-dont-card">
              <p class="nc-card-label">{{ block.settings.dont_label }}</p>
              {%- if block.settings.dont1 != blank -%}<div class="nc-card-item"><div class="nc-dot"></div>{{ block.settings.dont1 }}</div>{%- endif -%}
              {%- if block.settings.dont2 != blank -%}<div class="nc-card-item"><div class="nc-dot"></div>{{ block.settings.dont2 }}</div>{%- endif -%}
              {%- if block.settings.dont3 != blank -%}<div class="nc-card-item"><div class="nc-dot"></div>{{ block.settings.dont3 }}</div>{%- endif -%}
              {%- if block.settings.dont4 != blank -%}<div class="nc-card-item"><div class="nc-dot"></div>{{ block.settings.dont4 }}</div>{%- endif -%}
              {%- if block.settings.dont5 != blank -%}<div class="nc-card-item"><div class="nc-dot"></div>{{ block.settings.dont5 }}</div>{%- endif -%}
            </div>
          </div>
        </div>

      {%- endif -%}
    {%- endfor -%}
  </div>

  {%- comment -%} ─── FOOTER CTA ─── {%- endcomment -%}
  {%- if section.settings.cta_heading != blank -%}
    <div class="nc-footer-callout" style="background: {{ section.settings.cta_bg }};">
      <h2 style="color: {{ section.settings.cta_heading_color }};">{{ section.settings.cta_heading }}</h2>
      <p style="color: {{ section.settings.cta_text_color }};">{{ section.settings.cta_text }}</p>
      {%- if section.settings.cta_btn_text != blank -%}
        <a href="{{ section.settings.cta_btn_link }}" class="nc-btn" style="background: {{ section.settings.cta_btn_bg }}; color: {{ section.settings.cta_btn_text_color }};">{{ section.settings.cta_btn_text }}</a>
      {%- endif -%}
    </div>
  {%- endif -%}

</div>

<style>
  /* ─── NauNau Care Guide — scoped to .naunau-care ─── */
  .naunau-care { font-family: 'DM Sans', sans-serif; color: #2C2C2C; line-height: 1.6; }

  /* Hero */
  .naunau-care .nc-hero { padding: 80px 40px 70px; text-align: center; position: relative; overflow: hidden; }
  .naunau-care .nc-hero::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at 70% 30%, rgba(122,158,126,0.18) 0%, transparent 60%), radial-gradient(ellipse at 20% 80%, rgba(196,113,74,0.13) 0%, transparent 55%); }
  .naunau-care .nc-hero-eyebrow { font-family: 'DM Sans', sans-serif; font-size: 11px; font-weight: 500; letter-spacing: 0.2em; text-transform: uppercase; margin-bottom: 20px; position: relative; }
  .naunau-care .nc-hero h1 { font-family: 'Playfair Display', serif; font-size: clamp(2.2rem, 5vw, 3.6rem); font-weight: 700; line-height: 1.15; margin-bottom: 20px; position: relative; }
  .naunau-care .nc-hero h1 em { font-style: italic; }
  .naunau-care .nc-hero-sub { font-size: 1rem; font-weight: 300; max-width: 480px; margin: 0 auto; position: relative; }

  /* Quick wins */
  .naunau-care .nc-quick-wins { padding: 20px 40px; display: flex; justify-content: center; gap: 40px; flex-wrap: wrap; }
  .naunau-care .nc-quick-win { display: flex; align-items: center; gap: 8px; font-size: 0.82rem; font-weight: 500; letter-spacing: 0.03em; }
  .naunau-care .nc-icon { font-size: 1.1rem; }

  /* Container */
  .naunau-care .nc-container { max-width: 760px; margin: 0 auto; padding: 0 24px; }

  /* Sections */
  .naunau-care .nc-section { padding: 56px 0; border-bottom: 1px solid #D9D4CC; }
  .naunau-care .nc-section:last-child { border-bottom: none; }
  .naunau-care .nc-section-header { display: flex; align-items: flex-start; gap: 20px; margin-bottom: 28px; }
  .naunau-care .nc-section-emoji { font-size: 2rem; line-height: 1; flex-shrink: 0; margin-top: 2px; }
  .naunau-care .nc-section-tag { font-size: 10px; font-weight: 500; letter-spacing: 0.18em; text-transform: uppercase; margin-bottom: 4px; }
  .naunau-care .nc-section-title { font-family: 'Playfair Display', serif; font-size: 1.55rem; font-weight: 700; line-height: 1.2; }
  .naunau-care .nc-section-intro { font-size: 0.95rem; margin-bottom: 24px; line-height: 1.7; }

  /* Callout boxes */
  .naunau-care .nc-callout { border-radius: 12px; padding: 22px 26px; margin-bottom: 20px; display: flex; gap: 16px; align-items: flex-start; }
  .naunau-care .nc-sage { background-color: #E8F0E9; border-left: 3px solid #7A9E7E; }
  .naunau-care .nc-terracotta { background-color: #F9EDE6; border-left: 3px solid #C4714A; }
  .naunau-care .nc-cream { background-color: #F4EFE6; border-left: 3px solid #D9D4CC; }
  .naunau-care .nc-callout-icon { font-size: 1.4rem; flex-shrink: 0; margin-top: 1px; }
  .naunau-care .nc-callout-title { font-weight: 600; font-size: 0.9rem; color: #1A1A1A; margin-bottom: 5px; }
  .naunau-care .nc-callout-text { font-size: 0.88rem; color: #6B6B6B; line-height: 1.6; }

  /* Steps */
  .naunau-care .nc-steps { display: flex; flex-direction: column; gap: 14px; }
  .naunau-care .nc-step { display: flex; gap: 16px; align-items: flex-start; padding: 18px 20px; background: #FFFDF9; border-radius: 10px; border: 1px solid #D9D4CC; }
  .naunau-care .nc-step-num { width: 28px; height: 28px; color: white; border-radius: 50%; font-size: 0.78rem; font-weight: 600; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .naunau-care .nc-step-text { font-size: 0.9rem; color: #2C2C2C; line-height: 1.6; padding-top: 3px; }
  .naunau-care .nc-step-text strong { color: #1A1A1A; }

  /* Tips list */
  .naunau-care .nc-tips-list { list-style: none; display: flex; flex-direction: column; gap: 12px; padding: 0; }
  .naunau-care .nc-tips-list li { display: flex; gap: 12px; align-items: flex-start; font-size: 0.9rem; color: #2C2C2C; line-height: 1.6; }
  .naunau-care .nc-tips-list li::before { content: '\2192'; color: #7A9E7E; font-weight: 600; flex-shrink: 0; margin-top: 1px; }

  /* Do / Don't */
  .naunau-care .nc-do-dont { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 4px; }
  .naunau-care .nc-do-card, .naunau-care .nc-dont-card { border-radius: 10px; padding: 20px; }
  .naunau-care .nc-do-card { background: #E8F0E9; }
  .naunau-care .nc-dont-card { background: #F9EDE6; }
  .naunau-care .nc-card-label { font-size: 10px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; margin-bottom: 14px; }
  .naunau-care .nc-do-card .nc-card-label { color: #7A9E7E; }
  .naunau-care .nc-dont-card .nc-card-label { color: #C4714A; }
  .naunau-care .nc-card-item { font-size: 0.85rem; color: #2C2C2C; line-height: 1.5; padding: 6px 0; border-bottom: 1px solid rgba(0,0,0,0.06); display: flex; gap: 8px; }
  .naunau-care .nc-card-item:last-child { border-bottom: none; }
  .naunau-care .nc-dot { flex-shrink: 0; margin-top: 5px; width: 6px; height: 6px; border-radius: 50%; }
  .naunau-care .nc-do-card .nc-dot { background: #7A9E7E; }
  .naunau-care .nc-dont-card .nc-dot { background: #C4714A; }

  /* Footer CTA */
  .naunau-care .nc-footer-callout { padding: 56px 40px; text-align: center; }
  .naunau-care .nc-footer-callout h2 { font-family: 'Playfair Display', serif; font-size: 1.8rem; margin-bottom: 12px; }
  .naunau-care .nc-footer-callout p { font-size: 0.9rem; max-width: 400px; margin: 0 auto 24px; font-weight: 300; }
  .naunau-care .nc-btn { display: inline-block; font-size: 0.82rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; padding: 14px 32px; border-radius: 4px; text-decoration: none; transition: opacity 0.2s; }
  .naunau-care .nc-btn:hover { opacity: 0.85; }

  /* Animations */
  @keyframes ncFadeUp { from { opacity: 0; transform: translateY(18px); } to { opacity: 1; transform: translateY(0); } }
  .naunau-care .nc-animate { animation: ncFadeUp 0.5s ease both; }
  .naunau-care .nc-delay-1 { animation-delay: 0.1s; }
  .naunau-care .nc-delay-2 { animation-delay: 0.2s; }

  /* Mobile */
  @media (max-width: 520px) {
    .naunau-care .nc-do-dont { grid-template-columns: 1fr; }
    .naunau-care .nc-quick-wins { gap: 20px; }
  }
</style>

