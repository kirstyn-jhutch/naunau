{%- style -%}
  {{ section.settings.heading_font | font_face: font_display: 'swap' }}
  {{ section.settings.body_font | font_face: font_display: 'swap' }}
{%- endstyle -%}

<section id="naunau-community" class="naunau-community" {% if section.settings.bg_image != blank %}style="background-image: url('{{ section.settings.bg_image | image_url: width: 2000 }}');background-size: cover;background-position: center;"{% endif %}>
  <div class="naunau-community__inner">
    <p class="naunau-community__eyebrow">{{ section.settings.eyebrow }}</p>
    <h2 class="naunau-community__heading">{{ section.settings.heading }} <span>{{ section.settings.heading_highlight }}</span></h2>
    <p class="naunau-community__subtitle">{{ section.settings.subtitle }} <a href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener">{{ section.settings.instagram_handle }}</a></p>

    <div class="naunau-community__grid">
      {%- for i in (1..6) -%}
        {%- assign link_key = 'post_' | append: i | append: '_link' -%}
        {%- assign img_key = 'post_' | append: i | append: '_image' -%}
        {%- assign video_key = 'post_' | append: i | append: '_video' -%}
        {%- assign post_link = section.settings[link_key] | default: section.settings.instagram_url -%}
        <a href="{{ post_link }}" target="_blank" rel="noopener" class="naunau-community__card">
          {%- if section.settings[img_key] != blank -%}
            {{ section.settings[img_key] | image_url: width: 600 | image_tag: class: 'naunau-community__img', loading: 'lazy' }}
          {%- else -%}
            <div class="naunau-community__placeholder">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="{{ section.settings.eyebrow_color }}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
              <span>Add post {{ i }}</span>
            </div>
          {%- endif -%}
          {%- if section.settings[video_key] -%}
            <div class="naunau-community__play-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="white" stroke="white" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            </div>
          {%- endif -%}
        </a>
      {%- endfor -%}
    </div>

    <a href="{{ section.settings.cta_link | default: section.settings.instagram_url }}" target="_blank" rel="noopener" class="naunau-community__cta">
      {{ section.settings.cta_text }}
    </a>
  </div>
</section>

<style>
  .naunau-community {
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 2rem {{ section.settings.padding_bottom }}px;
    text-align: center;
    font-family: {{ section.settings.body_font.family | default: 'DM Sans' }}, {{ section.settings.body_font.fallback_families | default: 'sans-serif' }};
  }

  .naunau-community__inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .naunau-community__eyebrow {
    font-size: {{ section.settings.eyebrow_size }}px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: {{ section.settings.eyebrow_color }};
    margin-bottom: 0.75rem;
  }

  .naunau-community__heading {
    font-family: {{ section.settings.heading_font.family | default: 'DM Serif Display' }}, {{ section.settings.heading_font.fallback_families | default: 'serif' }};
    font-size: {{ section.settings.heading_size }}px;
    color: {{ section.settings.heading_color }};
    margin-bottom: 0.5rem;
    font-weight: 400;
  }

  .naunau-community__heading span {
    color: {{ section.settings.accent_color }};
    font-style: italic;
  }

  .naunau-community__subtitle {
    font-size: {{ section.settings.body_size }}px;
    color: {{ section.settings.text_color }};
    margin-bottom: 2.5rem;
  }

  .naunau-community__subtitle a {
    color: {{ section.settings.accent_color }};
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .naunau-community__subtitle a:hover {
    color: {{ section.settings.heading_color }};
  }

  .naunau-community__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.grid_columns }}, 1fr);
    gap: {{ section.settings.grid_gap }}px;
    margin-bottom: 2.5rem;
  }

  .naunau-community__card {
    position: relative;
    aspect-ratio: 1;
    border-radius: {{ section.settings.card_radius }}px;
    overflow: hidden;
    background: {{ section.settings.placeholder_bg }};
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    text-decoration: none;
  }

  .naunau-community__card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
  }

  .naunau-community__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .naunau-community__placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    color: {{ section.settings.eyebrow_color }};
    font-size: 0.85rem;
  }

  .naunau-community__play-icon {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: rgba(0, 0, 0, 0.45);
    border-radius: 50%;
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }

  .naunau-community__play-icon svg {
    margin-left: 3px;
  }

  .naunau-community__cta {
    display: inline-block;
    font-weight: 600;
    font-size: 1rem;
    color: {{ section.settings.btn_text_color }};
    background: {{ section.settings.btn_bg_color }};
    padding: 0.85rem 2rem;
    border-radius: {{ section.settings.btn_radius }}px;
    text-decoration: none;
    transition: background 0.3s ease;
  }

  .naunau-community__cta:hover {
    background: {{ section.settings.heading_color }};
  }

  @media (max-width: 768px) {
    .naunau-community {
      padding: 3rem 1.25rem;
    }

    .naunau-community__heading {
      font-size: calc({{ section.settings.heading_size }}px * 0.7);
    }

    .naunau-community__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

