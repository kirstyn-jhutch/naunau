{%- liquid
  assign total = 0
  assign star_sum = 0
  assign s5 = 0
  assign s4 = 0
  assign s3 = 0
  assign s2 = 0
  assign s1 = 0
  for block in section.blocks
    assign total = total | plus: 1
    assign stars = block.settings.stars | times: 1
    assign star_sum = star_sum | plus: stars
    case stars
      when 5
        assign s5 = s5 | plus: 1
      when 4
        assign s4 = s4 | plus: 1
      when 3
        assign s3 = s3 | plus: 1
      when 2
        assign s2 = s2 | plus: 1
      when 1
        assign s1 = s1 | plus: 1
    endcase
  endfor
  if total > 0
    assign avg_x10 = star_sum | times: 10 | divided_by: total
    assign avg_whole = avg_x10 | divided_by: 10
    assign avg_decimal = avg_x10 | modulo: 10
    assign p5 = s5 | times: 100 | divided_by: total
    assign p4 = s4 | times: 100 | divided_by: total
    assign p3 = s3 | times: 100 | divided_by: total
    assign p2 = s2 | times: 100 | divided_by: total
    assign p1 = s1 | times: 100 | divided_by: total
  else
    assign avg_whole = 0
    assign avg_decimal = 0
    assign p5 = 0
    assign p4 = 0
    assign p3 = 0
    assign p2 = 0
    assign p1 = 0
  endif
-%}

<div class="nn-reviews" style="max-width: {{ section.settings.max_width }}px;margin: 0 auto;padding: {{ section.settings.padding_y }}px {{ section.settings.padding_x }}px;">

  {%- if section.settings.heading != blank -%}
    <h2 class="nn-reviews__heading" style="
      font-family: 'Chewy', cursive;
      font-size: {{ section.settings.heading_size }}px;
      color: {{ section.settings.heading_color }};
      margin-bottom: 8px;
    ">{{ section.settings.heading }}</h2>
  {%- endif -%}
  {%- if section.settings.subheading != blank -%}
    <p class="nn-reviews__sub" style="color: #666;font-size: 15px;margin-bottom: 28px;">{{ section.settings.subheading }}</p>
  {%- endif -%}

  {%- comment -%} ─── Summary card ─── {%- endcomment -%}
  {%- if total > 0 -%}
    <div class="nn-reviews__summary">
      <div class="nn-reviews__score-side">
        <span class="nn-reviews__avg">{{ avg_whole }}.{{ avg_decimal }}</span>
        <div class="nn-reviews__avg-stars">
          {%- for i in (1..5) -%}
            {%- if i <= avg_whole -%}
              <span class="nn-reviews__star nn-reviews__star--full">★</span>
            {%- elsif i == avg_whole | plus: 1 and avg_decimal >= 5 -%}
              <span class="nn-reviews__star nn-reviews__star--full">★</span>
            {%- else -%}
              <span class="nn-reviews__star nn-reviews__star--empty">★</span>
            {%- endif -%}
          {%- endfor -%}
        </div>
        <span class="nn-reviews__count">{{ total }} review{{ total | pluralize: '', 's' }}</span>
      </div>
      <div class="nn-reviews__bars-side">
        <div class="nn-reviews__bar-row"><span class="nn-reviews__bar-label">5 ★</span><div class="nn-reviews__bar-track"><div class="nn-reviews__bar-fill" style="width: {{ p5 }}%;"></div></div></div>
        <div class="nn-reviews__bar-row"><span class="nn-reviews__bar-label">4 ★</span><div class="nn-reviews__bar-track"><div class="nn-reviews__bar-fill" style="width: {{ p4 }}%;"></div></div></div>
        <div class="nn-reviews__bar-row"><span class="nn-reviews__bar-label">3 ★</span><div class="nn-reviews__bar-track"><div class="nn-reviews__bar-fill" style="width: {{ p3 }}%;"></div></div></div>
        <div class="nn-reviews__bar-row"><span class="nn-reviews__bar-label">2 ★</span><div class="nn-reviews__bar-track"><div class="nn-reviews__bar-fill" style="width: {{ p2 }}%;"></div></div></div>
        <div class="nn-reviews__bar-row"><span class="nn-reviews__bar-label">1 ★</span><div class="nn-reviews__bar-track"><div class="nn-reviews__bar-fill" style="width: {{ p1 }}%;"></div></div></div>
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} ─── Individual review cards ─── {%- endcomment -%}
  <div class="nn-reviews__list">
    {%- for block in section.blocks -%}
      <div class="nn-reviews__card" {{ block.shopify_attributes }}>
        <div class="nn-reviews__card-header">
          <div class="nn-reviews__reviewer">
            <span class="nn-reviews__name">{{ block.settings.name }}</span>
            {%- if block.settings.verified -%}
              <span class="nn-reviews__verified">✓ Verified</span>
            {%- endif -%}
          </div>
          {%- if block.settings.date != blank -%}
            <span class="nn-reviews__date">{{ block.settings.date }}</span>
          {%- endif -%}
        </div>
        <div class="nn-reviews__card-stars">
          {%- for i in (1..5) -%}
            {%- if i <= block.settings.stars -%}
              <span class="nn-reviews__star nn-reviews__star--full">★</span>
            {%- else -%}
              <span class="nn-reviews__star nn-reviews__star--empty">★</span>
            {%- endif -%}
          {%- endfor -%}
        </div>
        {%- if block.settings.title != blank -%}
          <h4 class="nn-reviews__card-title">{{ block.settings.title }}</h4>
        {%- endif -%}
        <p class="nn-reviews__card-text">{{ block.settings.text }}</p>
      </div>
    {%- endfor -%}
  </div>
</div>

<style>
  .nn-reviews__heading {
    font-weight: 400;
  }
  .nn-reviews__summary {
    display: flex;
    gap: 32px;
    align-items: center;
    background: #fff;
    border: 1px solid #e0e0e0;
    border-radius: 12px;
    padding: 28px 32px;
    margin-bottom: 24px;
  }
  .nn-reviews__score-side {
    text-align: center;
    flex-shrink: 0;
    min-width: 110px;
  }
  .nn-reviews__avg {
    font-size: 48px;
    font-weight: 700;
    color: #1a1a1a;
    line-height: 1;
    display: block;
  }
  .nn-reviews__avg-stars {
    margin: 6px 0 4px;
  }
  .nn-reviews__star--full {
    color: #f0a500;
    font-size: 18px;
  }
  .nn-reviews__star--empty {
    color: #d4d4d4;
    font-size: 18px;
  }
  .nn-reviews__count {
    font-size: 14px;
    color: #888;
  }
  .nn-reviews__bars-side {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .nn-reviews__bar-row {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .nn-reviews__bar-label {
    font-size: 13px;
    color: #555;
    min-width: 32px;
    text-align: right;
    flex-shrink: 0;
  }
  .nn-reviews__bar-track {
    flex: 1;
    height: 10px;
    background: #e8e8e8;
    border-radius: 5px;
    overflow: hidden;
  }
  .nn-reviews__bar-fill {
    height: 100%;
    background: #f0a500;
    border-radius: 5px;
    transition: width 0.3s ease;
  }
  .nn-reviews__list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .nn-reviews__card {
    background: #fff;
    border: 1px solid #e0e0e0;
    border-radius: 12px;
    padding: 24px 28px;
  }
  .nn-reviews__card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 6px;
  }
  .nn-reviews__name {
    font-weight: 700;
    font-size: 16px;
    color: #1a1a1a;
  }
  .nn-reviews__verified {
    font-size: 12px;
    color: #30493b;
    font-weight: 500;
    margin-left: 8px;
  }
  .nn-reviews__date {
    font-size: 13px;
    color: #999;
    flex-shrink: 0;
  }
  .nn-reviews__card-stars {
    margin-bottom: 10px;
  }
  .nn-reviews__card-stars .nn-reviews__star--full {
    font-size: 16px;
  }
  .nn-reviews__card-stars .nn-reviews__star--empty {
    font-size: 16px;
  }
  .nn-reviews__card-title {
    font-weight: 600;
    font-size: 15px;
    color: #1a1a1a;
    margin: 0 0 8px;
  }
  .nn-reviews__card-text {
    font-size: 15px;
    color: #444;
    line-height: 1.65;
    margin: 0;
  }
  @media (max-width: 600px) {
    .nn-reviews__summary {
      flex-direction: column;
      text-align: center;
      padding: 20px;
    }
    .nn-reviews__card {
      padding: 18px 20px;
    }
  }
</style>

{% schema %}
{
  "name": "NauNau Reviews",
  "tag": "section",
  "class": "nn-reviews-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Reviews"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 18,
      "max": 40,
      "step": 1,
      "default": 28,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading colour",
      "default": "#1a1a1a"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Star summary at the top, individual reviews below. Nothing sells better than other customers."
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width",
      "min": 500,
      "max": 1200,
      "step": 50,
      "default": 800,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_y",
      "label": "Vertical padding",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_x",
