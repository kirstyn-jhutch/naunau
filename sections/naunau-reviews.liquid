{%- style -%}
  {{ section.settings.heading_font | font_face: font_display: 'swap' }}
  {{ section.settings.name_font | font_face: font_display: 'swap' }}
  {{ section.settings.body_font | font_face: font_display: 'swap' }}
{%- endstyle -%}

<section
  id="naunau-reviews"
  class="nn-reviews"
  style="
    background-color: {{ section.settings.bg_color }};
    {% if section.settings.bg_image != blank %}background-image: url('{{ section.settings.bg_image | image_url: width: 2000 }}');background-size: cover;background-position: center;{% endif %}
  "
>
  <div class="nn-reviews__inner" style="max-width: {{ section.settings.content_width }}px;">

    {%- if section.settings.eyebrow != blank -%}
      <p class="nn-reviews__eyebrow" style="
        color: {{ section.settings.eyebrow_color }};
        font-size: {{ section.settings.eyebrow_size }}px;
      ">{{ section.settings.eyebrow }}</p>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h2 class="nn-reviews__heading" style="
        font-family: {{ section.settings.heading_font.family }}, {{ section.settings.heading_font.fallback_families }};
        font-size: {{ section.settings.heading_size }}px;
        color: {{ section.settings.heading_color }};
      ">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.show_average and section.blocks.size > 0 -%}
      {%- assign total_stars = 0 -%}
      {%- assign review_count = 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'review' -%}
          {%- assign total_stars = total_stars | plus: block.settings.stars -%}
          {%- assign review_count = review_count | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
      {%- if review_count > 0 -%}
        {%- assign avg = total_stars | times: 10 | divided_by: review_count -%}
        {%- assign avg_whole = avg | divided_by: 10 -%}
        {%- assign avg_decimal = avg | modulo: 10 -%}
        <div class="nn-reviews__average">
          <div class="nn-reviews__avg-stars">
            {%- for i in (1..5) -%}
              {%- if i <= avg_whole -%}
                <svg width="20" height="20" viewBox="0 0 24 24" fill="{{ section.settings.star_color }}" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              {%- elsif i == avg_whole | plus: 1 and avg_decimal >= 5 -%}
                <svg width="20" height="20" viewBox="0 0 24 24" fill="{{ section.settings.star_color }}" stroke="none"><defs><linearGradient id="half-{{ section.id }}"><stop offset="50%" stop-color="{{ section.settings.star_color }}"/><stop offset="50%" stop-color="#ddd"/></linearGradient></defs><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="url(#half-{{ section.id }})"/></svg>
              {%- else -%}
                <svg width="20" height="20" viewBox="0 0 24 24" fill="#ddd" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              {%- endif -%}
            {%- endfor -%}
          </div>
          <span class="nn-reviews__avg-text" style="color: {{ section.settings.heading_color }};">{{ avg_whole }}.{{ avg_decimal }} out of 5 · {{ review_count }} {{ review_count | pluralize: 'review', 'reviews' }}</span>
        </div>
      {%- endif -%}
    {%- endif -%}

    <div class="nn-reviews__grid" style="
      grid-template-columns: repeat({{ section.settings.columns }}, 1fr);
      gap: {{ section.settings.card_gap }}px;
    ">
      {%- for block in section.blocks -%}
        {%- if block.type == 'review' -%}
          <div class="nn-reviews__card" {{ block.shopify_attributes }} style="
            background: {{ section.settings.card_bg }};
            border-radius: {{ section.settings.card_radius }}px;
            border: 1px solid {{ section.settings.card_border_color }};
          ">
            {%- comment -%} Stars {%- endcomment -%}
            <div class="nn-reviews__stars">
              {%- for i in (1..5) -%}
                {%- if i <= block.settings.stars -%}
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="{{ section.settings.star_color }}" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                {%- else -%}
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="#ddd" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                {%- endif -%}
              {%- endfor -%}
            </div>

            {%- comment -%} Review title {%- endcomment -%}
            {%- if block.settings.title != blank -%}
              <h3 class="nn-reviews__card-title" style="
                font-family: {{ section.settings.name_font.family }}, {{ section.settings.name_font.fallback_families }};
                color: {{ section.settings.title_color }};
                font-size: {{ section.settings.title_size }}px;
              ">{{ block.settings.title }}</h3>
            {%- endif -%}

            {%- comment -%} Review text {%- endcomment -%}
            <p class="nn-reviews__text" style="
              font-family: {{ section.settings.body_font.family }}, {{ section.settings.body_font.fallback_families }};
              color: {{ section.settings.text_color }};
              font-size: {{ section.settings.text_size }}px;
            ">{{ block.settings.text }}</p>

            {%- comment -%} Photo {%- endcomment -%}
            {%- if block.settings.photo != blank -%}
              <div class="nn-reviews__photo">
                <img
                  src="{{ block.settings.photo | image_url: width: 400 }}"
                  alt="{{ block.settings.name }}'s review"
                  loading="lazy"
                  style="border-radius: {{ section.settings.card_radius | minus: 4 }}px;"
                >
              </div>
            {%- endif -%}

            {%- comment -%} Reviewer info {%- endcomment -%}
            <div class="nn-reviews__reviewer">
              {%- if block.settings.avatar != blank -%}
                <img
                  class="nn-reviews__avatar"
                  src="{{ block.settings.avatar | image_url: width: 80 }}"
                  alt="{{ block.settings.name }}"
                  width="36"
                  height="36"
                >
              {%- else -%}
                <div class="nn-reviews__avatar-placeholder" style="background: {{ section.settings.star_color }};">
                  {{ block.settings.name | slice: 0 | upcase }}
                </div>
              {%- endif -%}
              <div class="nn-reviews__reviewer-info">
                <span class="nn-reviews__name" style="
                  font-family: {{ section.settings.name_font.family }}, {{ section.settings.name_font.fallback_families }};
                  color: {{ section.settings.name_color }};
                  font-size: {{ section.settings.name_size }}px;
                ">{{ block.settings.name }}</span>
                {%- if block.settings.verified -%}
                  <span class="nn-reviews__verified" style="color: {{ section.settings.star_color }};">✓ Verified buyer</span>
                {%- endif -%}
                {%- if block.settings.date != blank -%}
                  <span class="nn-reviews__date" style="color: {{ section.settings.text_color }};opacity:0.6;font-size:{{ section.settings.text_size | minus: 2 }}px;">{{ block.settings.date }}</span>
                {%- endif -%}
              </div>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</section>

<style>
  .nn-reviews {
    width: 100%;
  }
  .nn-reviews__inner {
    margin: 0 auto;
    padding: {{ section.settings.padding_y }}px {{ section.settings.padding_x }}px;
  }
  .nn-reviews__eyebrow {
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: 500;
    margin: 0 0 8px;
  }
  .nn-reviews__heading {
    text-align: center;
    margin: 0 0 12px;
  }
  .nn-reviews__average {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    margin-bottom: 32px;
  }
  .nn-reviews__avg-stars {
    display: flex;
    gap: 2px;
  }
  .nn-reviews__avg-text {
    font-size: 14px;
    opacity: 0.7;
  }
  .nn-reviews__grid {
    display: grid;
  }
  .nn-reviews__card {
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .nn-reviews__stars {
    display: flex;
    gap: 2px;
  }
  .nn-reviews__card-title {
    margin: 0;
    font-weight: 600;
  }
  .nn-reviews__text {
    margin: 0;
    line-height: 1.6;
  }
  .nn-reviews__photo {
    margin-top: 4px;
  }
  .nn-reviews__photo img {
    width: 100%;
    height: auto;
    display: block;
  }
  .nn-reviews__reviewer {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: auto;
    padding-top: 12px;
    border-top: 1px solid rgba(0,0,0,0.06);
  }
  .nn-reviews__avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    object-fit: cover;
  }
  .nn-reviews__avatar-placeholder {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-weight: 600;
    font-size: 14px;
    flex-shrink: 0;
  }
  .nn-reviews__reviewer-info {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }
  .nn-reviews__name {
    font-weight: 600;
  }
  .nn-reviews__verified {
    font-size: 11px;
    font-weight: 500;
  }
  .nn-reviews__date {
    font-size: 12px;
  }
  @media (max-width: 989px) {
    .nn-reviews__grid {
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }
  @media (max-width: 749px) {
    .nn-reviews__grid {
      grid-template-columns: 1fr !important;
    }
  }
</style>

{% schema %}
{
  "name": "NauNau Reviews",
  "tag": "section",
  "class": "nn-reviews-section",
  "settings": [
    {
      "type": "header",
      "content": "──── Header ────"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "What our customers say"
    },
    {
      "type": "range",
      "id": "eyebrow_size",
      "label": "Eyebrow size",
      "min": 10,
      "max": 18,
      "step": 1,
      "default": 12,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow colour",
      "default": "#7A9E7E"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Real reviews from real people"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading font",
      "default": "assistant_n7"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 18,
      "max": 48,
      "step": 1,
      "default": 32,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading colour",
      "default": "#1a1a1a"
    },
    {
      "type": "checkbox",
      "id": "show_average",
      "label": "Show average rating",
      "default": true
    },
    {
      "type": "header",
      "content": "──── Cards ────"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns (desktop)",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "card_gap",
      "label": "Card gap",
      "min": 8,
      "max": 40,
      "step": 2,
      "default": 20,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Card border colour",
      "default": "#e8e8e8"
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card corner radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "default": 12,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "──── Colours ────"
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star colour",
      "default": "#F5A623"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Review title colour",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Review text colour",
      "default": "#555555"
    },
    {
      "type": "color",
      "id": "name_color",
      "label": "Reviewer name colour",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "──── Typography ────"
    },
    {
      "type": "font_picker",
      "id": "name_font",
      "label": "Name / title font",
      "default": "assistant_n6"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Review title size",
      "min": 12,
      "max": 24,
      "step": 1,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "font_picker",
      "id": "body_font",
      "label": "Review text font",
      "default": "assistant_n4"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Review text size",
      "min": 12,
      "max": 20,
      "step": 1,
      "default": 14,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "name_size",
      "label": "Reviewer name size",
      "min": 12,
      "max": 20,
      "step": 1,
      "default": 14,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "──── Background ────"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section background",
      "default": "#FAF7F2"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background image"
    },
    {
      "type": "header",
      "content": "──── Layout ────"
    },
    {
      "type": "range",
      "id": "content_width",
      "label": "Content max-width",
      "min": 800,
      "max": 1400,
      "step": 50,
      "default": 1200,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_y",
      "label": "Vertical padding",
      "min": 20,
      "max": 100,
      "step": 5,
      "default": 60,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_x",
      "label": "Horizontal padding",
      "min": 10,
      "max": 60,
      "step": 5,
      "default": 24,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "range",
          "id": "stars",
          "label": "Star rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "text",
          "id": "title",
          "label": "Review title",
          "default": "Love these bags!"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Review text",
          "default": "These bags are amazing! So much better than plastic. They seal perfectly and are super easy to clean."
        },
        {
          "type": "image_picker",
          "id": "photo",
          "label": "Review photo (optional)"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Reviewer name",
          "default": "Sarah M."
        },
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "Avatar (optional)"
        },
        {
          "type": "checkbox",
          "id": "verified",
          "label": "Verified buyer badge",
          "default": true
        },
        {
          "type": "text",
          "id": "date",
          "label": "Date",
          "default": "March 2026"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "NauNau Reviews",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "stars": 5,
            "title": "Game changer for meal prep!",
            "text": "I use these for everything — marinating, freezing leftovers, snacks on the go. The seal is incredible and they clean up beautifully.",
            "name": "Sarah M.",
            "verified": true,
            "date": "March 2026"
          }
        },
        {
          "type": "review",
          "settings": {
            "stars": 5,
            "title": "Finally ditched plastic bags",
            "text": "These are so much sturdier than I expected. The silicone is thick, the seal is tight, and they look gorgeous in my kitchen.",
            "name": "James K.",
            "verified": true,
            "date": "February 2026"
          }
        },
        {
          "type": "review",
          "settings": {
            "stars": 4,
            "title": "Great quality, great cause",
            "text": "Love knowing I'm reducing waste with every use. The sage colour is beautiful and they hold up perfectly in the dishwasher.",
            "name": "Priya D.",
            "verified": true,
            "date": "January 2026"
          }
        }
      ]
    }
  ]
}
{% endschema %}
