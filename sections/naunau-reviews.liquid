{%- style -%}
  {{ section.settings.heading_font | font_face: font_display: 'swap' }}
  {{ section.settings.name_font | font_face: font_display: 'swap' }}
  {{ section.settings.body_font | font_face: font_display: 'swap' }}
{%- endstyle -%}

<section id="naunau-reviews" class="nn-reviews" style="background-color:{{ section.settings.bg_color }};">
  <div class="nn-reviews__inner" style="max-width:{{ section.settings.content_width }}px;">

    {%- if section.settings.heading != blank -%}
      <h2 class="nn-reviews__heading" style="font-family:{{ section.settings.heading_font.family }},{{ section.settings.heading_font.fallback_families }};font-size:{{ section.settings.heading_size }}px;color:{{ section.settings.heading_color }};text-align:center;margin:0 0 32px;">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="nn-reviews__grid" style="display:grid;grid-template-columns:repeat({{ section.settings.columns }},1fr);gap:{{ section.settings.card_gap }}px;">
      {%- for block in section.blocks -%}
        {%- if block.type == 'review' -%}
          <div class="nn-reviews__card" {{ block.shopify_attributes }} style="background:{{ section.settings.card_bg }};border-radius:{{ section.settings.card_radius }}px;border:1px solid {{ section.settings.card_border_color }};padding:24px;display:flex;flex-direction:column;gap:12px;">

            <div class="nn-reviews__stars" style="display:flex;gap:2px;">
              {%- for i in (1..5) -%}
                {%- if i <= block.settings.stars -%}
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="{{ section.settings.star_color }}" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                {%- else -%}
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="#ddd" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                {%- endif -%}
              {%- endfor -%}
            </div>

            {%- if block.settings.title != blank -%}
              <h3 style="margin:0;font-weight:600;font-family:{{ section.settings.name_font.family }},{{ section.settings.name_font.fallback_families }};color:{{ section.settings.heading_color }};font-size:{{ section.settings.title_size }}px;">{{ block.settings.title }}</h3>
            {%- endif -%}

            <p style="margin:0;line-height:1.6;font-family:{{ section.settings.body_font.family }},{{ section.settings.body_font.fallback_families }};color:{{ section.settings.text_color }};font-size:{{ section.settings.text_size }}px;">{{ block.settings.text }}</p>

            {%- if block.settings.photo != blank -%}
              <img src="{{ block.settings.photo | image_url: width: 400 }}" alt="{{ block.settings.name }}" loading="lazy" style="width:100%;height:auto;border-radius:{{ section.settings.card_radius | minus: 4 }}px;">
            {%- endif -%}

            <div style="display:flex;align-items:center;gap:10px;margin-top:auto;padding-top:12px;border-top:1px solid rgba(0,0,0,0.06);">
              <div style="width:36px;height:36px;border-radius:50%;background:{{ section.settings.star_color }};display:flex;align-items:center;justify-content:center;color:#fff;font-weight:600;font-size:14px;flex-shrink:0;">{{ block.settings.name | slice: 0 | upcase }}</div>
              <div style="display:flex;flex-direction:column;gap:1px;">
                <span style="font-weight:600;font-family:{{ section.settings.name_font.family }},{{ section.settings.name_font.fallback_families }};color:{{ section.settings.heading_color }};font-size:{{ section.settings.name_size }}px;">{{ block.settings.name }}</span>
                {%- if block.settings.verified -%}
                  <span style="font-size:11px;font-weight:500;color:{{ section.settings.star_color }};">&#10003; Verified buyer</span>
                {%- endif -%}
                {%- if block.settings.date != blank -%}
                  <span style="font-size:12px;color:{{ section.settings.text_color }};opacity:0.6;">{{ block.settings.date }}</span>
                {%- endif -%}
              </div>
            </div>

          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</section>

<style>
  .nn-reviews__inner {
    margin: 0 auto;
    padding: {{ section.settings.padding_y }}px {{ section.settings.padding_x }}px;
  }
  @media (max-width: 989px) {
    .nn-reviews__grid { grid-template-columns: repeat(2, 1fr) !important; }
  }
  @media (max-width: 749px) {
    .nn-reviews__grid { grid-template-columns: 1fr !important; }
  }
</style>

{% schema %}
{
  "name": "NauNau Reviews",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What our customers say"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading font",
      "default": "assistant_n7"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 18,
      "max": 48,
      "step": 1,
      "default": 32,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading colour",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "card_gap",
      "label": "Card gap",
      "min": 8,
      "max": 40,
      "step": 2,
      "default": 20,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Card border",
      "default": "#e8e8e8"
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "default": 12,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star colour",
      "default": "#F5A623"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text colour",
      "default": "#555555"
    },
    {
      "type": "font_picker",
      "id": "name_font",
      "label": "Name font",
      "default": "assistant_n6"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title size",
      "min": 12,
      "max": 24,
      "step": 1,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "font_picker",
      "id": "body_font",
      "label": "Body font",
      "default": "assistant_n4"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 12,
      "max": 20,
      "step": 1,
      "default": 14,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "name_size",
      "label": "Name size",
      "min": 12,
      "max": 20,
      "step": 1,
      "default": 14,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#FAF7F2"
    },
    {
      "type": "range",
      "id": "content_width",
      "label": "Max width",
      "min": 800,
      "max": 1400,
      "step": 50,
      "default": 1200,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_y",
      "label": "Vertical padding",
      "min": 20,
      "max": 100,
      "step": 5,
      "default": 60,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_x",
      "label": "Horizontal padding",
      "min": 10,
      "max": 60,
      "step": 5,
      "default": 24,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "range",
          "id": "stars",
          "label": "Stars",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Love these bags!"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Review text",
          "default": "These bags are amazing quality. The seal is perfect and they clean up so easily."
        },
        {
          "type": "image_picker",
          "id": "photo",
          "label": "Photo (optional)"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Sarah M."
        },
        {
          "type": "checkbox",
          "id": "verified",
          "label": "Verified buyer",
          "default": true
        },
        {
          "type": "text",
          "id": "date",
          "label": "Date",
          "default": "March 2026"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "NauNau Reviews",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "stars": 5,
            "title": "Game changer for meal prep!",
            "text": "I use these for everything. The seal is incredible and they clean up beautifully.",
            "name": "Sarah M.",
            "verified": true,
            "date": "March 2026"
          }
        },
        {
          "type": "review",
          "settings": {
            "stars": 5,
            "title": "Finally ditched plastic bags",
            "text": "So much sturdier than expected. The silicone is thick and the seal is tight.",
            "name": "James K.",
            "verified": true,
            "date": "February 2026"
          }
        },
        {
          "type": "review",
          "settings": {
            "stars": 4,
            "title": "Great quality, great cause",
            "text": "Love knowing I'm reducing waste with every use. The sage colour is beautiful.",
            "name": "Priya D.",
            "verified": true,
            "date": "January 2026"
          }
        }
      ]
    }
  ]
}
{% endschema %}
