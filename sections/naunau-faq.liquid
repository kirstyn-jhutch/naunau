{%- style -%}
  {{ section.settings.eyebrow_font | font_face: font_display: 'swap' }}
  {{ section.settings.line1_font | font_face: font_display: 'swap' }}
  {{ section.settings.line2_font | font_face: font_display: 'swap' }}
  {{ section.settings.subline_font | font_face: font_display: 'swap' }}
  {{ section.settings.heading_font | font_face: font_display: 'swap' }}
  {{ section.settings.body_font | font_face: font_display: 'swap' }}
{%- endstyle -%}

<section id="faq" class="nn-faq" {% if section.settings.bg_image != blank %}style="background-image: url('{{ section.settings.bg_image | image_url: width: 2000 }}');background-size: cover;background-position: center;"{% endif %}>
  <div class="nn-faq__container">
    <div class="nn-faq__left">
      <span class="nn-faq__eyebrow" style="color: {{ section.settings.eyebrow_color }};font-size: {{ section.settings.eyebrow_size }}px;font-family: {{ section.settings.eyebrow_font.family }}, {{ section.settings.eyebrow_font.fallback_families }};">{{ section.settings.eyebrow }}</span>
      <h2 class="nn-faq__heading">
        <span class="nn-faq__line1" style="color: {{ section.settings.line1_color }};font-size: {{ section.settings.line1_size }}px;font-family: {{ section.settings.line1_font.family }}, {{ section.settings.line1_font.fallback_families }};">{{ section.settings.heading_line1 }}</span><br>
        <em class="nn-faq__line2" style="color: {{ section.settings.line2_color }};font-size: {{ section.settings.line2_size }}px;font-family: {{ section.settings.line2_font.family }}, {{ section.settings.line2_font.fallback_families }};">{{ section.settings.heading_line2 }}</em>
      </h2>
      <p class="nn-faq__subline" style="color: {{ section.settings.subline_color }};font-size: {{ section.settings.subline_size }}px;font-family: {{ section.settings.subline_font.family }}, {{ section.settings.subline_font.fallback_families }};">{{ section.settings.subline }}</p>
      <a href="mailto:{{ section.settings.email }}" class="nn-faq__email">{{ section.settings.email }}</a>
    </div>
    <div class="nn-faq__right">
      {%- for block in section.blocks -%}
        {%- if block.type == 'faq' -%}
          <div class="nn-faq__item" data-faq-item {{ block.shopify_attributes }}>
            <button class="nn-faq__question" data-faq-toggle style="color: {{ block.settings.block_question_color | default: section.settings.heading_color }};font-size: {{ block.settings.block_question_size }}px;">
              <span>{{ block.settings.question }}</span>
              <span class="nn-faq__icon">+</span>
            </button>
            <div class="nn-faq__answer" data-faq-answer>
              <div class="nn-faq__answer-inner">
                <p style="color: {{ block.settings.block_answer_color | default: section.settings.text_color }};font-size: {{ block.settings.block_answer_size }}px;">{{ block.settings.answer }}</p>
                {%- if block.settings.link_text != blank -%}
                  <a href="{{ block.settings.link_url }}" class="nn-faq__ideas-link">{{ block.settings.link_text }}</a>
                {%- endif -%}
              </div>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
  <div class="nn-faq__extra">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'heading' -%}
          <div class="nn-extra-block" style="text-align: {{ block.settings.alignment }};" {{ block.shopify_attributes }}>
            <{{ block.settings.tag }} class="nn-extra-heading" style="font-size: {{ block.settings.size }}px;color: {{ block.settings.color }};">{{ block.settings.text }}</{{ block.settings.tag }}>
          </div>
        {%- when 'text' -%}
          <div class="nn-extra-block" style="text-align: {{ block.settings.alignment }};" {{ block.shopify_attributes }}>
            <div class="nn-extra-text" style="font-size: {{ block.settings.size }}px;color: {{ block.settings.color }};">{{ block.settings.content }}</div>
          </div>
        {%- when 'button' -%}
          <div class="nn-extra-block" style="text-align: {{ block.settings.alignment }};" {{ block.shopify_attributes }}>
            <a href="{{ block.settings.link }}" class="nn-extra-btn" style="background: {{ block.settings.bg_color }};color: {{ block.settings.text_color }};border-radius: {{ block.settings.radius }}px;font-size: {{ block.settings.size }}px;">{{ block.settings.text }}</a>
          </div>
        {%- when 'image' -%}
          <div class="nn-extra-block" style="text-align: {{ block.settings.alignment }};" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              <div style="display: inline-block;border-radius: {{ block.settings.radius }}px;overflow: hidden;max-width: {{ block.settings.max_width }}px;width: 100%;">
                {{ block.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', class: 'nn-extra-img' }}
              </div>
            {%- endif -%}
          </div>
        {%- when 'link' -%}
          <div class="nn-extra-block" style="text-align: {{ block.settings.alignment }};" {{ block.shopify_attributes }}>
            <a href="{{ block.settings.url }}" class="nn-extra-link" style="font-size: {{ block.settings.size }}px;color: {{ block.settings.color }};">{{ block.settings.text }}</a>
          </div>
      {%- endcase -%}
    {%- endfor -%}
  </div>
</section>

<style>
  .nn-faq {
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 2rem {{ section.settings.padding_bottom }}px;
    font-family: {{ section.settings.body_font.family | default: 'DM Sans' }}, {{ section.settings.body_font.fallback_families | default: 'sans-serif' }};
  }
  .nn-faq__container {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 4rem;
    align-items: start;
  }
  .nn-faq__left {
    position: sticky;
    top: 6rem;
  }
  .nn-faq__eyebrow {
    font-size: {{ section.settings.eyebrow_size }}px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: {{ section.settings.eyebrow_color }};
    margin-bottom: 0.75rem;
    display: block;
  }
  .nn-faq__heading {
    font-family: {{ section.settings.heading_font.family | default: 'DM Serif Display' }}, {{ section.settings.heading_font.fallback_families | default: 'serif' }};
    font-size: {{ section.settings.heading_size }}px;
    font-weight: 400;
    color: {{ section.settings.heading_color }};
    line-height: 1.15;
    margin: 0 0 1rem 0;
  }
  .nn-faq__heading em {
    color: {{ section.settings.accent_color }};
    font-style: italic;
  }
  .nn-faq__subline {
    font-size: {{ section.settings.body_size }}px;
    color: {{ section.settings.text_color }};
    margin-bottom: 1rem;
  }
  .nn-faq__email {
    font-size: 1rem;
    font-weight: 500;
    color: {{ section.settings.accent_color }};
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .nn-faq__email:hover {
    color: {{ section.settings.heading_color }};
  }
  .nn-faq__item {
    border-bottom: 1px solid {{ section.settings.divider_color }};
  }
  .nn-faq__item:first-child {
    border-top: 1px solid {{ section.settings.divider_color }};
  }
  .nn-faq__question {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.25rem 0;
    background: none;
    border: none;
    cursor: pointer;
    font-family: {{ section.settings.body_font.family | default: 'DM Sans' }}, {{ section.settings.body_font.fallback_families | default: 'sans-serif' }};
    font-size: {{ section.settings.question_size }}px;
    font-weight: 500;
    color: {{ section.settings.heading_color }};
    text-align: left;
    gap: 1rem;
  }
  .nn-faq__question:hover {
    color: {{ section.settings.accent_color }};
  }
  .nn-faq__icon {
    font-size: 1.5rem;
    font-weight: 300;
    color: {{ section.settings.eyebrow_color }};
    transition: transform 0.3s ease, color 0.3s ease;
    flex-shrink: 0;
    line-height: 1;
  }
  .nn-faq__item.is-open .nn-faq__icon {
    transform: rotate(45deg);
    color: {{ section.settings.accent_color }};
  }
  .nn-faq__answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s ease;
  }
  .nn-faq__item.is-open .nn-faq__answer {
    max-height: 300px;
  }
  .nn-faq__answer-inner {
    padding: 0 0 1.25rem 0;
  }
  .nn-faq__answer-inner p {
    font-size: {{ section.settings.body_size }}px;
    line-height: 1.7;
    color: {{ section.settings.text_color }};
    margin: 0;
  }
  .nn-faq__ideas-link {
    display: inline-block;
    margin-top: 0.75rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: {{ section.settings.accent_color }};
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .nn-faq__ideas-link:hover {
    color: {{ section.settings.heading_color }};
  }
  .nn-faq__extra {
    max-width: 1200px;
    margin: 0 auto;
  }
  .nn-extra-block { margin: 1.5rem 0; }
  .nn-extra-heading {
    font-family: {{ section.settings.heading_font.family | default: 'DM Serif Display' }}, {{ section.settings.heading_font.fallback_families | default: 'serif' }};
    font-weight: 400;
    margin: 0;
  }
  .nn-extra-text { line-height: 1.7; }
  .nn-extra-btn {
    display: inline-block;
    font-weight: 600;
    padding: 0.85rem 2rem;
    text-decoration: none;
    transition: opacity 0.3s ease;
  }
  .nn-extra-btn:hover { opacity: 0.85; }
  .nn-extra-img { width: 100%; display: block; }
  .nn-extra-link {
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .nn-extra-link:hover { opacity: 0.7; }

  @media (max-width: 768px) {
    .nn-faq { padding: 3rem 1.25rem; }
    .nn-faq__container {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .nn-faq__left {
      position: static;
    }
    .nn-faq__heading { font-size: calc({{ section.settings.heading_size }}px * 0.8); }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const items = document.querySelectorAll('[data-faq-item]');
    items.forEach(function (item) {
      const toggle = item.querySelector('[data-faq-toggle]');
      toggle.addEventListener('click', function () {
        const isOpen = item.classList.contains('is-open');
        items.forEach(function (i) {
          i.classList.remove('is-open');
        });
        if (!isOpen) {
          item.classList.add('is-open');
        }
      });
    });
  });
</script>

