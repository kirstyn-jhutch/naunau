{%- style -%}
  {{ section.settings.line1_font | font_face: font_display: 'swap' }}
  {{ section.settings.line2_font | font_face: font_display: 'swap' }}
  {{ section.settings.line3_font | font_face: font_display: 'swap' }}
  {{ section.settings.line4_font | font_face: font_display: 'swap' }}
  {{ section.settings.btn_font | font_face: font_display: 'swap' }}
{%- endstyle -%}

<section
  id="hero"
  class="nn-hero"
  style="
    background-color: {{ section.settings.bg_color }};
    {% if section.settings.bg_image != blank %}background-image: url('{{ section.settings.bg_image | image_url: width: 2000 }}');background-size: cover;background-position: {{ section.settings.bg_position }};{% endif %}
    min-height: {{ section.settings.section_height }}vh;
  "
>
  {%- if section.settings.overlay_opacity > 0 -%}
    <div class="nn-hero__overlay" style="background: {{ section.settings.overlay_color }};opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"></div>
  {%- endif -%}

  <div class="nn-hero__container" style="text-align: {{ section.settings.text_align }};max-width: {{ section.settings.content_width }}px;">
    {%- if section.settings.line1 != blank -%}
      <span class="nn-hero__line1" style="
        display: block;
        color: {{ section.settings.line1_color }};
        font-size: {{ section.settings.line1_size }}px;
        font-family: {{ section.settings.line1_font.family }}, {{ section.settings.line1_font.fallback_families }};
        {% if section.settings.line1_bold %}font-weight: bold;{% endif %}
        {% if section.settings.line1_italic %}font-style: italic;{% endif %}
        line-height: {{ section.settings.line1_line_height }};
        letter-spacing: {{ section.settings.line1_spacing }}px;
        margin-bottom: {{ section.settings.line1_margin_bottom }}px;
      ">{{ section.settings.line1 }}</span>
    {%- endif -%}

    {%- if section.settings.line2 != blank -%}
      <span class="nn-hero__line2" style="
        display: block;
        color: {{ section.settings.line2_color }};
        font-size: {{ section.settings.line2_size }}px;
        font-family: {{ section.settings.line2_font.family }}, {{ section.settings.line2_font.fallback_families }};
        {% if section.settings.line2_bold %}font-weight: bold;{% endif %}
        {% if section.settings.line2_italic %}font-style: italic;{% endif %}
        line-height: {{ section.settings.line2_line_height }};
        letter-spacing: {{ section.settings.line2_spacing }}px;
        margin-bottom: {{ section.settings.line2_margin_bottom }}px;
      ">{{ section.settings.line2 }}{% if section.settings.line2_accent != blank %} <span style="
        color: {{ section.settings.line2_accent_color }};
        font-family: 'Chewy', cursive;
        font-weight: normal;
        font-style: normal;
        font-size: {{ section.settings.line2_accent_size }}px;
      ">{{ section.settings.line2_accent }}</span>{% endif %}</span>
    {%- endif -%}

    {%- if section.settings.line3 != blank -%}
      <span class="nn-hero__line3" style="
        display: block;
        color: {{ section.settings.line3_color }};
        font-size: {{ section.settings.line3_size }}px;
        font-family: {{ section.settings.line3_font.family }}, {{ section.settings.line3_font.fallback_families }};
        {% if section.settings.line3_bold %}font-weight: bold;{% endif %}
        {% if section.settings.line3_italic %}font-style: italic;{% endif %}
        line-height: {{ section.settings.line3_line_height }};
        letter-spacing: {{ section.settings.line3_spacing }}px;
        margin-bottom: {{ section.settings.line3_margin_bottom }}px;
      ">{{ section.settings.line3 }}</span>
    {%- endif -%}

    {%- if section.settings.line4 != blank -%}
      <span class="nn-hero__line4" style="
        display: block;
        color: {{ section.settings.line4_color }};
        font-size: {{ section.settings.line4_size }}px;
        font-family: {{ section.settings.line4_font.family }}, {{ section.settings.line4_font.fallback_families }};
        {% if section.settings.line4_bold %}font-weight: bold;{% endif %}
        {% if section.settings.line4_italic %}font-style: italic;{% endif %}
        line-height: {{ section.settings.line4_line_height }};
        letter-spacing: {{ section.settings.line4_spacing }}px;
        margin-bottom: {{ section.settings.line4_margin_bottom }}px;
      ">{{ section.settings.line4 }}</span>
    {%- endif -%}

    {%- if section.settings.btn_text != blank -%}
      <a href="{{ section.settings.btn_link }}" class="nn-hero__btn" style="
        display: inline-block;
        background: {{ section.settings.btn_bg }};
        color: {{ section.settings.btn_text_color }};
        font-size: {{ section.settings.btn_size }}px;
        font-family: {{ section.settings.btn_font.family }}, {{ section.settings.btn_font.fallback_families }};
        border-radius: {{ section.settings.btn_radius }}px;
        padding: {{ section.settings.btn_padding_y }}px {{ section.settings.btn_padding_x }}px;
        text-decoration: none;
        border: {{ section.settings.btn_border_width }}px solid {{ section.settings.btn_border_color }};
        margin-top: {{ section.settings.btn_margin_top }}px;
        letter-spacing: 1px;
        transition: opacity 0.3s;
      ">{{ section.settings.btn_text }}</a>
    {%- endif -%}
  </div>

  {%- comment -%} Extra blocks — heading, text, button, image, link {%- endcomment -%}
  <div class="nn-hero__extra">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'heading' -%}
          <div class="nn-extra-block" style="text-align: {{ block.settings.alignment }};" {{ block.shopify_attributes }}>
            <{{ block.settings.tag }} class="nn-extra-heading" style="font-size: {{ block.settings.size }}px;color: {{ block.settings.color }};">{{ block.settings.text }}</{{ block.settings.tag }}>
          </div>
        {%- when 'text' -%}
          <div class="nn-extra-block" style="text-align: {{ block.settings.alignment }};" {{ block.shopify_attributes }}>
            <div class="nn-extra-text" style="font-size: {{ block.settings.size }}px;color: {{ block.settings.color }};">{{ block.settings.content }}</div>
          </div>
        {%- when 'button' -%}
          <div class="nn-extra-block" style="text-align: {{ block.settings.alignment }};" {{ block.shopify_attributes }}>
            <a href="{{ block.settings.link }}" class="nn-extra-btn" style="background: {{ block.settings.bg_color }};color: {{ block.settings.text_color }};border-radius: {{ block.settings.radius }}px;font-size: {{ block.settings.size }}px;padding: 12px 28px;display: inline-block;text-decoration: none;">{{ block.settings.text }}</a>
          </div>
        {%- when 'image' -%}
          <div class="nn-extra-block" style="text-align: {{ block.settings.alignment }};" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: block.settings.width }}" alt="{{ block.settings.image.alt | default: '' }}" width="{{ block.settings.width }}" style="max-width: 100%;height: auto;">
            {%- endif -%}
          </div>
        {%- when 'link' -%}
          <div class="nn-extra-block" style="text-align: {{ block.settings.alignment }};" {{ block.shopify_attributes }}>
            <a href="{{ block.settings.url }}" class="nn-extra-link" style="color: {{ block.settings.color }};font-size: {{ block.settings.size }}px;">{{ block.settings.text }}</a>
          </div>
      {%- endcase -%}
    {%- endfor -%}
  </div>
</section>

<style>
  .nn-hero {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
    overflow: hidden;
  }
  .nn-hero__overlay {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    pointer-events: none;
    z-index: 1;
  }
  .nn-hero__container {
    position: relative;
    z-index: 2;
    padding: 60px 24px;
    width: 100%;
  }
  .nn-hero__btn:hover {
    opacity: 0.85;
  }
  .nn-hero__extra {
    position: relative;
    z-index: 2;
    width: 100%;
    padding: 0 24px;
  }
  @media (max-width: 749px) {
    .nn-hero__line1,
    .nn-hero__line2,
    .nn-hero__line3,
    .nn-hero__line4 {
      font-size: clamp(14px, 5vw, inherit) !important;
    }
    .nn-hero__container {
      padding: 40px 16px;
    }
  }
</style>

