<div class="nn-sg-section" style="padding: {{ section.settings.padding_y }}px {{ section.settings.padding_x }}px;max-width: {{ section.settings.max_width }}px;margin: 0 auto;">
  {%- if section.settings.heading != blank -%}
    <h2 class="nn-sg__heading" style="
      font-family: 'Chewy', cursive;
      font-size: {{ section.settings.heading_size }}px;
      color: {{ section.settings.heading_color }};
      text-align: {{ section.settings.heading_align }};
      margin-bottom: 24px;
    ">{{ section.settings.heading }}</h2>
  {%- endif -%}

  <div class="nn-sg__tabs">
    <button class="nn-sg__tab nn-sg__tab--active" data-nn-tab="tab1">{{ section.settings.tab1_name }}</button>
    <button class="nn-sg__tab" data-nn-tab="tab2">{{ section.settings.tab2_name }}</button>
    <button class="nn-sg__tab" data-nn-tab="tab3">{{ section.settings.tab3_name }}</button>
    <button class="nn-sg__tab" data-nn-tab="tab4">{{ section.settings.tab4_name }}</button>
  </div>

  {%- comment -%} Tab 1 {%- endcomment -%}
  <div class="nn-sg__panel nn-sg__panel--active" data-nn-panel="tab1">
    <div class="nn-sg__card">
      <span class="nn-sg__emoji">{{ section.settings.t1_emoji1 }}</span>
      <p class="nn-sg__desc">{{ section.settings.t1_desc1 }}</p>
    </div>
    <div class="nn-sg__card">
      <span class="nn-sg__emoji">{{ section.settings.t1_emoji2 }}</span>
      <p class="nn-sg__desc">{{ section.settings.t1_desc2 }}</p>
    </div>
    <div class="nn-sg__card">
      <span class="nn-sg__emoji">{{ section.settings.t1_emoji3 }}</span>
      <p class="nn-sg__desc">{{ section.settings.t1_desc3 }}</p>
    </div>
    <div class="nn-sg__card">
      <span class="nn-sg__emoji">{{ section.settings.t1_emoji4 }}</span>
      <p class="nn-sg__desc">{{ section.settings.t1_desc4 }}</p>
    </div>
  </div>

  {%- comment -%} Tab 2 {%- endcomment -%}
  <div class="nn-sg__panel" data-nn-panel="tab2">
    <div class="nn-sg__card">
      <span class="nn-sg__emoji">{{ section.settings.t2_emoji1 }}</span>
      <p class="nn-sg__desc">{{ section.settings.t2_desc1 }}</p>
    </div>
    <div class="nn-sg__card">
      <span class="nn-sg__emoji">{{ section.settings.t2_emoji2 }}</span>
      <p class="nn-sg__desc">{{ section.settings.t2_desc2 }}</p>
    </div>
    <div class="nn-sg__card">
      <span class="nn-sg__emoji">{{ section.settings.t2_emoji3 }}</span>
      <p class="nn-sg__desc">{{ section.settings.t2_desc3 }}</p>
    </div>
    <div class="nn-sg__card">
      <span class="nn-sg__emoji">{{ section.settings.t2_emoji4 }}</span>
      <p class="nn-sg__desc">{{ section.settings.t2_desc4 }}</p>
    </div>
  </div>

  {%- comment -%} Tab 3 {%- endcomment -%}
  <div class="nn-sg__panel" data-nn-panel="tab3">
    <div class="nn-sg__card">
      <span class="nn-sg__emoji">{{ section.settings.t3_emoji1 }}</span>
      <p class="nn-sg__desc">{{ section.settings.t3_desc1 }}</p>
    </div>
    <div class="nn-sg__card">
      <span class="nn-sg__emoji">{{ section.settings.t3_emoji2 }}</span>
