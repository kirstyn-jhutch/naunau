      <p class="nn-sg__desc">{{ section.settings.t4_desc2 }}</p>
    </div>
    <div class="nn-sg__card">
      <span class="nn-sg__emoji">{{ section.settings.t4_emoji3 }}</span>
      <p class="nn-sg__desc">{{ section.settings.t4_desc3 }}</p>
    </div>
    <div class="nn-sg__card">
      <span class="nn-sg__emoji">{{ section.settings.t4_emoji4 }}</span>
      <p class="nn-sg__desc">{{ section.settings.t4_desc4 }}</p>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.nn-sg__tab').forEach(function(tab) {
      tab.addEventListener('click', function() {
        var parent = this.closest('.nn-sg-section');
        parent.querySelectorAll('.nn-sg__tab').forEach(function(t) { t.classList.remove('nn-sg__tab--active'); });
        parent.querySelectorAll('.nn-sg__panel').forEach(function(p) { p.classList.remove('nn-sg__panel--active'); });
        this.classList.add('nn-sg__tab--active');
        parent.querySelector('[data-nn-panel="' + this.getAttribute('data-nn-tab') + '"]').classList.add('nn-sg__panel--active');
      });
    });
  });
</script>

<style>
  .nn-sg-section {
    width: 100%;
  }
  .nn-sg__heading {
    font-weight: 400;
  }
  .nn-sg__tabs {
    display: flex;
    gap: 8px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }
  .nn-sg__tab {
    padding: 10px 20px;
    border: 1.5px solid #d1d5db;
    border-radius: 30px;
    background: transparent;
    color: #555;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
    font-family: inherit;
  }
  .nn-sg__tab:hover {
    border-color: #30493b;
    color: #30493b;
  }
  .nn-sg__tab--active {
    background: #30493b !important;
    color: #fff !important;
    border-color: #30493b !important;
  }
  .nn-sg__panel {
    display: none;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .nn-sg__panel--active {
    display: grid;
  }
  .nn-sg__card {
    background: #f5f5f0;
    border-radius: 14px;
    padding: 20px;
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }
  .nn-sg__emoji {
    font-size: 32px;
    flex-shrink: 0;
    line-height: 1;
  }
  .nn-sg__desc {
    font-size: 15px;
    color: #333;
    margin: 0;
    line-height: 1.5;
    padding-top: 4px;
  }
  .nn-sg__desc strong {
    font-weight: 700;
    color: #1a1a1a;
  }
  @media (max-width: 480px) {
    .nn-sg__tabs {
      gap: 6px;
    }
    .nn-sg__tab {
      padding: 8px 14px;
      font-size: 12px;
    }
    .nn-sg__card {
      padding: 14px;
    }
    .nn-sg__emoji {
      font-size: 26px;
    }
    .nn-sg__desc {
      font-size: 13px;
    }
  }
</style>

