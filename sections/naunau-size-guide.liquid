    </div>
  </div>

  {%- comment -%} Tab 4 {%- endcomment -%}
  <div class="nn-sg__panel" data-nn-panel="tab4">
    <div class="nn-sg__card">
      <span class="nn-sg__emoji">{{ section.settings.t4_emoji1 }}</span>
      <p class="nn-sg__desc">{{ section.settings.t4_desc1 }}</p>
    </div>
    <div class="nn-sg__card">
