<section class="nn-ideas" id="ideas">
  <div class="nn-ideas__container">
    <h2 class="nn-ideas__heading">{{ section.settings.heading }}</h2>
    <div class="nn-ideas__grid">
      {%- for block in section.blocks -%}
        <div class="nn-ideas__card" {{ block.shopify_attributes }}>
          <span class="nn-ideas__tag {% if block.settings.tag_color == 'berry' %}nn-ideas__tag--berry{% else %}nn-ideas__tag--green{% endif %}">{{ block.settings.category }}</span>
          <h3 class="nn-ideas__card-title">{{ block.settings.title }}</h3>
          <p class="nn-ideas__card-desc">{{ block.settings.description }}</p>
          {%- if block.settings.link_url != blank -%}
            <a href="{{ block.settings.link_url }}" class="nn-ideas__card-link">{{ block.settings.link_text | default: "Read More →" }}</a>
          {%- else -%}
            <span class="nn-ideas__card-link">{{ block.settings.link_text | default: "Read More →" }}</span>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .nn-ideas {
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 2rem {{ section.settings.padding_bottom }}px;
    font-family: 'DM Sans', sans-serif;
  }
  .nn-ideas__container {
    max-width: 1200px;
    margin: 0 auto;
  }
  .nn-ideas__heading {
    font-family: 'DM Serif Display', serif;
    font-size: {{ section.settings.heading_size }}px;
    font-weight: 400;
    color: {{ section.settings.heading_color }};
    text-align: center;
    margin: 0 0 3rem 0;
  }
  .nn-ideas__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns }}, 1fr);
    gap: {{ section.settings.card_gap }}px;
  }
  .nn-ideas__card {
    background: {{ section.settings.card_bg_color }};
    border-radius: {{ section.settings.card_radius }}px;
    padding: 2rem 1.75rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
  }
  .nn-ideas__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
  }
  .nn-ideas__tag {
    display: inline-block;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.3rem 0.85rem;
    border-radius: 50px;
    color: #fff;
    margin-bottom: 1rem;
    width: fit-content;
  }
  .nn-ideas__tag--berry {
    background: {{ section.settings.tag_berry_color }};
  }
  .nn-ideas__tag--green {
    background: {{ section.settings.tag_green_color }};
  }
  .nn-ideas__card-title {
    font-family: 'DM Serif Display', serif;
    font-size: {{ section.settings.card_title_size }}px;
    font-weight: 400;
    color: {{ section.settings.heading_color }};
    margin: 0 0 0.6rem 0;
  }
  .nn-ideas__card-desc {
    font-family: 'DM Sans', sans-serif;
    font-size: {{ section.settings.body_size }}px;
    line-height: 1.65;
    color: {{ section.settings.text_color }};
    margin: 0 0 1.25rem 0;
    flex-grow: 1;
  }
  .nn-ideas__card-link {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    color: {{ section.settings.link_color }};
    text-decoration: none;
  }
  a.nn-ideas__card-link:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @media (max-width: 900px) {
    .nn-ideas__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 560px) {
    .nn-ideas { padding: 3rem 1.25rem; }
    .nn-ideas__grid {
      grid-template-columns: 1fr;
    }
    .nn-ideas__heading { font-size: calc({{ section.settings.heading_size }}px * 0.8); }
  }
</style>

{% schema %}
{
