{%- style -%}
  {{ section.settings.heading_font_picker | font_face: font_display: 'swap' }}
  {{ section.settings.heading_font | font_face: font_display: 'swap' }}
  {{ section.settings.body_font | font_face: font_display: 'swap' }}
{%- endstyle -%}

<section class="nn-ideas" id="ideas" {% if section.settings.bg_image != blank %}style="background-image: url('{{ section.settings.bg_image | image_url: width: 2000 }}');background-size: cover;background-position: center;"{% endif %}>
  <div class="nn-ideas__container">
    <h2 class="nn-ideas__heading" style="color: {{ section.settings.heading_color_picker }};font-size: {{ section.settings.heading_size }}px;font-family: {{ section.settings.heading_font_picker.family }}, {{ section.settings.heading_font_picker.fallback_families }};">{{ section.settings.heading }}</h2>
    <div class="nn-ideas__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'idea' -%}
          <div class="nn-ideas__card" style="background: {{ block.settings.block_bg_color | default: section.settings.card_bg_color }};border-radius: {{ block.settings.block_radius }}px;" {{ block.shopify_attributes }}>
            <span class="nn-ideas__tag {% if block.settings.tag_color == 'berry' %}nn-ideas__tag--berry{% else %}nn-ideas__tag--green{% endif %}">{{ block.settings.category }}</span>
            <h3 class="nn-ideas__card-title" style="color: {{ block.settings.block_title_color | default: section.settings.heading_color }};font-size: {{ block.settings.block_title_size }}px;">{{ block.settings.title }}</h3>
            <p class="nn-ideas__card-desc" style="color: {{ block.settings.block_text_color | default: section.settings.text_color }};font-size: {{ block.settings.block_body_size }}px;">{{ block.settings.description }}</p>
            {%- if block.settings.link_url != blank -%}
              <a href="{{ block.settings.link_url }}" class="nn-ideas__card-link" style="color: {{ block.settings.block_link_color | default: section.settings.link_color }};">{{ block.settings.link_text | default: "Read More →" }}</a>
            {%- else -%}
              <span class="nn-ideas__card-link" style="color: {{ block.settings.block_link_color | default: section.settings.link_color }};">{{ block.settings.link_text | default: "Read More →" }}</span>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
  <div class="nn-ideas__extra">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'heading' -%}
          <div class="nn-extra-block" style="text-align: {{ block.settings.alignment }};" {{ block.shopify_attributes }}>
            <{{ block.settings.tag }} class="nn-extra-heading" style="font-size: {{ block.settings.size }}px;color: {{ block.settings.color }};">{{ block.settings.text }}</{{ block.settings.tag }}>
          </div>
        {%- when 'text' -%}
          <div class="nn-extra-block" style="text-align: {{ block.settings.alignment }};" {{ block.shopify_attributes }}>
            <div class="nn-extra-text" style="font-size: {{ block.settings.size }}px;color: {{ block.settings.color }};">{{ block.settings.content }}</div>
          </div>
        {%- when 'button' -%}
          <div class="nn-extra-block" style="text-align: {{ block.settings.alignment }};" {{ block.shopify_attributes }}>
            <a href="{{ block.settings.link }}" class="nn-extra-btn" style="background: {{ block.settings.bg_color }};color: {{ block.settings.text_color }};border-radius: {{ block.settings.radius }}px;font-size: {{ block.settings.size }}px;">{{ block.settings.text }}</a>
          </div>
        {%- when 'image' -%}
          <div class="nn-extra-block" style="text-align: {{ block.settings.alignment }};" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              <div style="display: inline-block;border-radius: {{ block.settings.radius }}px;overflow: hidden;max-width: {{ block.settings.max_width }}px;width: 100%;">
                {{ block.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', class: 'nn-extra-img' }}
              </div>
            {%- endif -%}
          </div>
        {%- when 'link' -%}
          <div class="nn-extra-block" style="text-align: {{ block.settings.alignment }};" {{ block.shopify_attributes }}>
            <a href="{{ block.settings.url }}" class="nn-extra-link" style="font-size: {{ block.settings.size }}px;color: {{ block.settings.color }};">{{ block.settings.text }}</a>
          </div>
      {%- endcase -%}
    {%- endfor -%}
  </div>
</section>

<style>
  .nn-ideas {
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 2rem {{ section.settings.padding_bottom }}px;
    font-family: {{ section.settings.body_font.family | default: 'DM Sans' }}, {{ section.settings.body_font.fallback_families | default: 'sans-serif' }};
  }
  .nn-ideas__container {
    max-width: 1200px;
    margin: 0 auto;
  }
  .nn-ideas__heading {
    font-family: {{ section.settings.heading_font.family | default: 'DM Serif Display' }}, {{ section.settings.heading_font.fallback_families | default: 'serif' }};
    font-size: {{ section.settings.heading_size }}px;
    font-weight: 400;
    color: {{ section.settings.heading_color }};
    text-align: center;
    margin: 0 0 3rem 0;
  }
  .nn-ideas__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns }}, 1fr);
    gap: {{ section.settings.card_gap }}px;
  }
  .nn-ideas__card {
    background: {{ section.settings.card_bg_color }};
    border-radius: {{ section.settings.card_radius }}px;
    padding: 2rem 1.75rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
  }
  .nn-ideas__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
  }
  .nn-ideas__tag {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.3rem 0.85rem;
    border-radius: 50px;
    color: #fff;
    margin-bottom: 1rem;
    width: fit-content;
  }
  .nn-ideas__tag--berry {
    background: {{ section.settings.tag_berry_color }};
  }
  .nn-ideas__tag--green {
    background: {{ section.settings.tag_green_color }};
  }
  .nn-ideas__card-title {
    font-family: {{ section.settings.heading_font.family | default: 'DM Serif Display' }}, {{ section.settings.heading_font.fallback_families | default: 'serif' }};
    font-size: {{ section.settings.card_title_size }}px;
    font-weight: 400;
    color: {{ section.settings.heading_color }};
    margin: 0 0 0.6rem 0;
  }
  .nn-ideas__card-desc {
    font-size: {{ section.settings.body_size }}px;
    line-height: 1.65;
    color: {{ section.settings.text_color }};
    margin: 0 0 1.25rem 0;
    flex-grow: 1;
  }
  .nn-ideas__card-link {
    font-size: 0.85rem;
    font-weight: 600;
    color: {{ section.settings.link_color }};
    text-decoration: none;
  }
  a.nn-ideas__card-link:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .nn-ideas__extra {
    max-width: 1200px;
    margin: 0 auto;
  }
  .nn-extra-block { margin: 1.5rem 0; }
  .nn-extra-heading {
    font-family: {{ section.settings.heading_font.family | default: 'DM Serif Display' }}, {{ section.settings.heading_font.fallback_families | default: 'serif' }};
    font-weight: 400;
    margin: 0;
  }
  .nn-extra-text { line-height: 1.7; }
  .nn-extra-btn {
    display: inline-block;
    font-weight: 600;
    padding: 0.85rem 2rem;
    text-decoration: none;
    transition: opacity 0.3s ease;
  }
  .nn-extra-btn:hover { opacity: 0.85; }
  .nn-extra-img { width: 100%; display: block; }
  .nn-extra-link {
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .nn-extra-link:hover { opacity: 0.7; }

  @media (max-width: 900px) {
    .nn-ideas__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 560px) {
    .nn-ideas { padding: 3rem 1.25rem; }
    .nn-ideas__grid {
      grid-template-columns: 1fr;
    }
    .nn-ideas__heading { font-size: calc({{ section.settings.heading_size }}px * 0.8); }
  }
</style>

