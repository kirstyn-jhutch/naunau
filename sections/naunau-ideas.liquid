<section class="nn-ideas" id="ideas">
  <div class="nn-ideas__container">
    <h2 class="nn-ideas__heading">{{ section.settings.heading }}</h2>
    <div class="nn-ideas__grid">
      {%- for block in section.blocks -%}
        <div class="nn-ideas__card" {{ block.shopify_attributes }}>
          <span class="nn-ideas__tag {% if block.settings.tag_color == 'berry' %}nn-ideas__tag--berry{% else %}nn-ideas__tag--green{% endif %}">{{ block.settings.tag }}</span>
          <h3 class="nn-ideas__card-title">{{ block.settings.title }}</h3>
          <p class="nn-ideas__card-desc">{{ block.settings.description }}</p>
          {%- if block.settings.link_text != blank -%}
            <a href="{{ block.settings.link_url }}" class="nn-ideas__card-link">{{ block.settings.link_text }}</a>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .nn-ideas {
    background: #fff;
    padding: 5rem 2rem;
    font-family: 'DM Sans', sans-serif;
  }
  .nn-ideas__container {
    max-width: 1200px;
    margin: 0 auto;
  }
  .nn-ideas__heading {
    font-family: 'DM Serif Display', serif;
    font-size: 2.5rem;
    font-weight: 400;
    color: #30493B;
    text-align: center;
    margin: 0 0 3rem 0;
  }
  .nn-ideas__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .nn-ideas__card {
    background: #FAF7F2;
    border-radius: 16px;
    padding: 2rem 1.75rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
  }
  .nn-ideas__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
  }
  .nn-ideas__tag {
    display: inline-block;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.3rem 0.85rem;
    border-radius: 50px;
    color: #fff;
    margin-bottom: 1rem;
    width: fit-content;
  }
  .nn-ideas__tag--berry {
    background: #731A47;
  }
  .nn-ideas__tag--green {
    background: #30493B;
  }
  .nn-ideas__card-title {
    font-family: 'DM Serif Display', serif;
    font-size: 1.2rem;
    font-weight: 400;
    color: #30493B;
    margin: 0 0 0.6rem 0;
  }
  .nn-ideas__card-desc {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9rem;
    line-height: 1.65;
    color: #3D3D3D;
    margin: 0 0 1.25rem 0;
    flex-grow: 1;
  }
  .nn-ideas__card-link {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    color: #731A47;
    text-decoration: none;
  }
  .nn-ideas__card-link:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @media (max-width: 900px) {
    .nn-ideas__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 560px) {
    .nn-ideas { padding: 3rem 1.25rem; }
    .nn-ideas__grid {
      grid-template-columns: 1fr;
    }
    .nn-ideas__heading { font-size: 2rem; }
  }
</style>

{% schema %}
{
  "name": "NauNau Ideas",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "More than just a bag."
    }
  ],
  "blocks": [
    {
      "type": "idea",
      "name": "Idea Card",
      "settings": [
        {
          "type": "text",
          "id": "tag",
          "label": "Tag label",
          "default": "Meal Prep"
        },
        {
          "type": "select",
          "id": "tag_color",
          "label": "Tag color",
          "options": [
            { "value": "berry", "label": "Berry" },
            { "value": "green", "label": "Green" }
          ],
          "default": "berry"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Card title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Card description"
        },
        {
          "type": "text",
          "id": "link_text",
          "label": "Link text",
          "default": "Read More →"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "NauNau Ideas",
      "blocks": [
        {
          "type": "idea",
          "settings": {
            "tag": "Meal Prep",
            "tag_color": "berry",
            "title": "Prep once, eat all week",
            "description": "Batch-cook your favourites and store them in NauNau bags. Grab, heat, done — weeknight dinners sorted.",
            "link_text": "Read More →"
          }
        },
        {
          "type": "idea",
          "settings": {
            "tag": "Lunchbox",
            "tag_color": "green",
            "title": "Lunchbox wins for picky eaters",
            "description": "Pack sandwiches, fruit, and snacks without the cling wrap chaos. Easy to clean, easy to repack.",
            "link_text": "Read More →"
          }
        },
        {
          "type": "idea",
          "settings": {
            "tag": "Freezer Tips",
            "tag_color": "berry",
            "title": "Freeze smarter, waste less",
            "description": "Flat-freeze soups, sauces, and smoothie packs. Stack them neatly and save space in your freezer.",
            "link_text": "Read More →"
          }
        },
        {
          "type": "idea",
          "settings": {
            "tag": "Baby & Kids",
            "tag_color": "green",
            "title": "Safe storage for little ones",
            "description": "Store purees, snacks, and teething rusks in BPA-free silicone. Sterilise with boiling water — no stress.",
            "link_text": "Read More →"
          }
        },
        {
          "type": "idea",
          "settings": {
            "tag": "Travel",
            "tag_color": "berry",
            "title": "Your travel toiletry bag, sorted",
            "description": "Shampoo, sunscreen, snacks on the go. Leakproof seal means no surprises in your bag.",
            "link_text": "Read More →"
          }
        },
        {
          "type": "idea",
          "settings": {
            "tag": "Recipes",
            "tag_color": "green",
            "title": "Marinate like a pro",
            "description": "Toss your chicken, steak, or veggies into a NauNau bag with marinade. Seal, massage, fridge — done.",
            "link_text": "Read More →"
          }
        }
      ]
    }
  ]
}
{% endschema %}
