{%- style -%}
  {{ section.settings.heading_font | font_face: font_display: 'swap' }}
  {{ section.settings.body_font | font_face: font_display: 'swap' }}
{%- endstyle -%}

<section id="eco" class="nn-eco" {% if section.settings.bg_image != blank %}style="background-image: url('{{ section.settings.bg_image | image_url: width: 2000 }}');background-size: cover;background-position: center;"{% endif %}>
  <div class="nn-eco__container">
    <div class="nn-eco__left">
      <span class="nn-eco__eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 class="nn-eco__heading">{{ section.settings.heading_line1 }}<br><em>{{ section.settings.heading_line2 }}</em></h2>
      <p class="nn-eco__desc">{{ section.settings.description }}</p>
      {%- if section.settings.cta_text != blank -%}
        <a href="{{ section.settings.cta_link }}" class="nn-eco__cta">{{ section.settings.cta_text }}</a>
      {%- endif -%}
    </div>
    <div class="nn-eco__right">
      {%- for block in section.blocks -%}
        {%- if block.type == 'stat' -%}
          <div class="nn-eco__stat-box" style="background: {{ block.settings.block_bg_color | default: section.settings.card_bg_color }};border-radius: {{ block.settings.block_radius }}px;" {{ block.shopify_attributes }}>
            <span class="nn-eco__stat-number" style="color: {{ block.settings.block_number_color | default: section.settings.heading_color }};font-size: {{ block.settings.block_number_size }}px;">{{ block.settings.stat_number }}</span>
            <span class="nn-eco__stat-label" style="color: {{ block.settings.block_label_color | default: section.settings.text_color }};font-size: {{ block.settings.block_label_size }}px;">{{ block.settings.stat_label }}</span>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
  <div class="nn-eco__extra">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'heading' -%}
          <div class="nn-extra-block" style="text-align: {{ block.settings.alignment }};" {{ block.shopify_attributes }}>
            <{{ block.settings.tag }} class="nn-extra-heading" style="font-size: {{ block.settings.size }}px;color: {{ block.settings.color }};">{{ block.settings.text }}</{{ block.settings.tag }}>
          </div>
        {%- when 'text' -%}
          <div class="nn-extra-block" style="text-align: {{ block.settings.alignment }};" {{ block.shopify_attributes }}>
            <div class="nn-extra-text" style="font-size: {{ block.settings.size }}px;color: {{ block.settings.color }};">{{ block.settings.content }}</div>
          </div>
        {%- when 'button' -%}
          <div class="nn-extra-block" style="text-align: {{ block.settings.alignment }};" {{ block.shopify_attributes }}>
            <a href="{{ block.settings.link }}" class="nn-extra-btn" style="background: {{ block.settings.bg_color }};color: {{ block.settings.text_color }};border-radius: {{ block.settings.radius }}px;font-size: {{ block.settings.size }}px;">{{ block.settings.text }}</a>
          </div>
        {%- when 'image' -%}
          <div class="nn-extra-block" style="text-align: {{ block.settings.alignment }};" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              <div style="display: inline-block;border-radius: {{ block.settings.radius }}px;overflow: hidden;max-width: {{ block.settings.max_width }}px;width: 100%;">
                {{ block.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', class: 'nn-extra-img' }}
              </div>
            {%- endif -%}
          </div>
        {%- when 'link' -%}
          <div class="nn-extra-block" style="text-align: {{ block.settings.alignment }};" {{ block.shopify_attributes }}>
            <a href="{{ block.settings.url }}" class="nn-extra-link" style="font-size: {{ block.settings.size }}px;color: {{ block.settings.color }};">{{ block.settings.text }}</a>
          </div>
      {%- endcase -%}
    {%- endfor -%}
  </div>
</section>

<style>
  .nn-eco {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 2rem {{ section.settings.padding_bottom }}px;
    font-family: {{ section.settings.body_font.family | default: 'DM Sans' }}, {{ section.settings.body_font.fallback_families | default: 'sans-serif' }};
  }
  .nn-eco__container {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }
  .nn-eco__eyebrow {
    font-size: {{ section.settings.eyebrow_size }}px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: {{ section.settings.text_color }};
    margin-bottom: 0.75rem;
    display: block;
  }
  .nn-eco__heading {
    font-family: {{ section.settings.heading_font.family | default: 'DM Serif Display' }}, {{ section.settings.heading_font.fallback_families | default: 'serif' }};
    font-size: {{ section.settings.heading_size }}px;
    font-weight: 400;
    color: {{ section.settings.heading_color }};
    line-height: 1.15;
    margin: 0 0 1.25rem 0;
  }
  .nn-eco__heading em {
    color: {{ section.settings.accent_color }};
    font-style: italic;
  }
  .nn-eco__desc {
    font-size: {{ section.settings.body_size }}px;
    line-height: 1.7;
    color: {{ section.settings.text_color }};
    margin-bottom: 2rem;
    max-width: 440px;
  }
  .nn-eco__cta {
    display: inline-block;
    font-size: 0.95rem;
    font-weight: 600;
    color: {{ section.settings.btn_text_color }};
    background: {{ section.settings.btn_bg_color }};
    border: none;
    padding: 0.85rem 2rem;
    border-radius: {{ section.settings.btn_radius }}px;
    text-decoration: none;
    transition: all 0.3s ease;
    cursor: pointer;
  }
  .nn-eco__cta:hover {
    background: {{ section.settings.heading_color }};
    color: {{ section.settings.btn_bg_color }};
  }
  .nn-eco__right {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ section.settings.card_gap }}px;
  }
  .nn-eco__stat-box {
    background: {{ section.settings.card_bg_color }};
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid {{ section.settings.card_border_color }};
    border-radius: {{ section.settings.card_radius }}px;
    padding: 1.75rem 1.5rem;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .nn-eco__stat-box:hover,
  .nn-eco__stat-box:active {
    transform: scale(1.08);
    box-shadow: 0 8px 24px rgba(48,73,59,0.15);
    z-index: 1;
  }
  .nn-eco__stat-number {
    display: block;
    font-family: {{ section.settings.heading_font.family | default: 'DM Serif Display' }}, {{ section.settings.heading_font.fallback_families | default: 'serif' }};
    font-size: {{ section.settings.stat_number_size }}px;
    font-weight: 400;
    color: {{ section.settings.heading_color }};
    margin-bottom: 0.4rem;
    line-height: 1;
  }
  .nn-eco__stat-label {
    font-size: {{ section.settings.stat_label_size }}px;
    color: {{ section.settings.text_color }};
    line-height: 1.5;
  }
  .nn-eco__extra {
    max-width: 1200px;
    margin: 0 auto;
  }
  .nn-extra-block { margin: 1.5rem 0; }
  .nn-extra-heading {
    font-family: {{ section.settings.heading_font.family | default: 'DM Serif Display' }}, {{ section.settings.heading_font.fallback_families | default: 'serif' }};
    font-weight: 400;
    margin: 0;
  }
  .nn-extra-text { line-height: 1.7; }
  .nn-extra-btn {
    display: inline-block;
    font-weight: 600;
    padding: 0.85rem 2rem;
    text-decoration: none;
    transition: opacity 0.3s ease;
  }
  .nn-extra-btn:hover { opacity: 0.85; }
  .nn-extra-img { width: 100%; display: block; }
  .nn-extra-link {
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .nn-extra-link:hover { opacity: 0.7; }

  @media (max-width: 768px) {
    .nn-eco { padding: 3rem 1.25rem; }
    .nn-eco__container {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .nn-eco__heading { font-size: calc({{ section.settings.heading_size }}px * 0.8); }
    .nn-eco__right {
      grid-template-columns: 1fr 1fr;
      gap: 0.75rem;
    }
  }
  @media (max-width: 480px) {
    .nn-eco__right { grid-template-columns: 1fr; }
    .nn-eco__stat-box { padding: 1.25rem 1rem; }
  }
</style>

