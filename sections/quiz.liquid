{% liquid
  assign heading = section.settings.heading | default: "Find Your Perfect NauNau"
  assign subtitle = section.settings.subtitle | default: "Answer 3 quick questions and we'll match you with the right size"
  assign btn_color = section.settings.button_color | default: "#30493b"
  assign btn_text = section.settings.button_text_color | default: "#ffffff"
  assign bg_color = section.settings.bg_color | default: "#fafafa"

  assign q1_title = section.settings.q1_title | default: "What will you use it for?"
  assign q1_a = section.settings.q1_a | default: "Snacks"
  assign q1_b = section.settings.q1_b | default: "Meal prep"
  assign q1_c = section.settings.q1_c | default: "Big batches"

  assign q2_title = section.settings.q2_title | default: "How many people are you feeding?"
  assign q2_a = section.settings.q2_a | default: "Just me"
  assign q2_b = section.settings.q2_b | default: "Two of us"
  assign q2_c = section.settings.q2_c | default: "The whole family"

  assign q3_title = section.settings.q3_title | default: "Where will it live?"
  assign q3_a = section.settings.q3_a | default: "Fridge"
  assign q3_b = section.settings.q3_b | default: "On the go"
  assign q3_c = section.settings.q3_c | default: "Freezer"

  assign r1_product = section.settings.r1_product
  assign r1_name = section.settings.r1_name | default: "The Snack · 400ml"
  assign r1_desc = section.settings.r1_desc | default: "Perfect for small snacks, dips, and single portions. Compact enough to toss in any bag."

  assign r2_product = section.settings.r2_product
  assign r2_name = section.settings.r2_name | default: "The Sandwich · 800ml"
  assign r2_desc = section.settings.r2_desc | default: "Ideal for sandwiches, wraps, and lunch portions for one or two. Your everyday go-to."

  assign r3_product = section.settings.r3_product
  assign r3_name = section.settings.r3_name | default: "The Crescent · 1000ml"
  assign r3_desc = section.settings.r3_desc | default: "Great for meal prep, salads, and feeding a couple. Fits nicely in the fridge or freezer."

  assign r4_product = section.settings.r4_product
  assign r4_name = section.settings.r4_name | default: "The Keeper · 2000ml"
  assign r4_desc = section.settings.r4_desc | default: "Built for big batches, family meals, and bulk storage. The one that does it all."

  assign shop_btn_label = section.settings.shop_btn_label | default: "Shop Now"
  assign retake_label = section.settings.retake_label | default: "Retake Quiz"
%}

<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Chewy&family=Playfair+Display:wght@400;700&family=DM+Sans:wght@400;500;700&display=swap">

<style>
  .naunau-quiz {
    background: {{ bg_color }};
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 60px 20px;
  }
  .naunau-quiz .quiz-container {
    max-width: 800px;
    width: 100%;
    margin: 0 auto;
  }
  .naunau-quiz .quiz-header {
    text-align: center;
    margin-bottom: 40px;
  }
  .naunau-quiz .quiz-heading {
    font-family: 'Chewy', cursive;
    font-size: 72px;
    color: {{ btn_color }};
    margin-bottom: 12px;
    line-height: 1.05;
    letter-spacing: -1px;
    white-space: nowrap;
  }
  .naunau-quiz .quiz-heading-svg {
    width: 100%;
    overflow: visible;
    display: block;
    margin: 0 auto;
  }
  .naunau-quiz .quiz-heading-svg text {
    font-family: 'Chewy', cursive;
    font-size: 52px;
    fill: url(#quiz-heading-gradient);
  }
  .naunau-quiz .quiz-subtitle {
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    color: #666;
  }

  .naunau-quiz .quiz-body {
    max-width: 420px;
    margin: 0 auto;
  }

  /* progress bar */
  .naunau-quiz .progress-bar {
    width: 100%;
    height: 6px;
    background: #e0e0e0;
    border-radius: 3px;
    margin-bottom: 40px;
    overflow: hidden;
  }
  .naunau-quiz .progress-fill {
    height: 100%;
    background: {{ btn_color }};
    border-radius: 3px;
    transition: width 0.4s ease;
    width: 0%;
  }

  /* steps */
  .naunau-quiz .quiz-step {
    display: none;
    text-align: center;
  }
  .naunau-quiz .quiz-step.active {
    display: block;
  }
  .naunau-quiz .step-number {
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    color: #999;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 8px;
  }
  .naunau-quiz .question-title {
    font-family: 'Playfair Display', serif;
    font-size: 28px;
    color: #1a1a1a;
    margin-bottom: 32px;
  }
  .naunau-quiz .options {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .naunau-quiz .option-btn {
    background: #fff;
    border: 2px solid #e0e0e0;
    border-radius: 12px;
    padding: 18px 24px;
    font-family: 'DM Sans', sans-serif;
    font-size: 16px;
    font-weight: 500;
    color: #1a1a1a;
    cursor: pointer;
    transition: all 0.2s ease;
    text-align: left;
  }
  .naunau-quiz .option-btn:hover {
    border-color: {{ btn_color }};
    background: #f8faf8;
  }
  .naunau-quiz .option-btn.selected {
    border-color: {{ btn_color }};
    background: {{ btn_color }};
    color: #fff;
  }

  /* result */
  .naunau-quiz .quiz-result {
    display: none;
    text-align: center;
  }
  .naunau-quiz .quiz-result.active {
    display: block;
  }
  .naunau-quiz .result-image {
    max-width: 280px;
    height: auto;
    border-radius: 16px;
    margin: 20px auto 24px;
    display: block;
  }
  .naunau-quiz .result-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    color: #999;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 8px;
  }
  .naunau-quiz .result-name {
    font-family: 'Playfair Display', serif;
    font-size: 32px;
    color: #1a1a1a;
    margin-bottom: 16px;
  }
  .naunau-quiz .result-desc {
    font-family: 'DM Sans', sans-serif;
    font-size: 16px;
    color: #555;
    line-height: 1.6;
    margin-bottom: 32px;
    max-width: 440px;
    margin-left: auto;
    margin-right: auto;
  }
  .naunau-quiz .result-shop-btn {
    display: inline-block;
    background: {{ btn_color }};
    color: {{ btn_text }};
    font-family: 'DM Sans', sans-serif;
    font-size: 16px;
    font-weight: 700;
    padding: 16px 40px;
    border-radius: 10px;
    text-decoration: none;
    transition: opacity 0.2s;
    margin-bottom: 16px;
  }
  .naunau-quiz .result-shop-btn:hover {
    opacity: 0.85;
  }
  .naunau-quiz .retake-btn {
    display: block;
    background: none;
    border: none;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    color: #999;
    cursor: pointer;
    margin: 0 auto;
    text-decoration: underline;
    padding: 8px;
  }
  .naunau-quiz .retake-btn:hover {
    color: #666;
  }

  @media (max-width: 600px) {
    .naunau-quiz {
      padding: 40px 16px;
      min-height: auto;
    }
    .naunau-quiz .quiz-heading {
      font-size: 44px;
      white-space: normal;
    }
    .naunau-quiz .question-title {
      font-size: 22px;
    }
    .naunau-quiz .result-name {
      font-size: 26px;
    }
  }
</style>

<div class="naunau-quiz">
  <div class="quiz-container">
    <div class="quiz-header">
      <svg class="quiz-heading-svg" viewBox="0 0 800 160" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <path id="quiz-curve" d="M 50,140 Q 400,20 750,140" fill="none" />
          <linearGradient id="quiz-heading-gradient" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="{{ btn_color }}" />
            <stop offset="50%" stop-color="#6b8f71" />
            <stop offset="100%" stop-color="#b8ceba" />
          </linearGradient>
        </defs>
        <text>
          <textPath href="#quiz-curve" startOffset="50%" text-anchor="middle">{{ heading }}</textPath>
        </text>
      </svg>
      <p class="quiz-subtitle">{{ subtitle }}</p>
    </div>

    <div class="quiz-body">
    <div class="progress-bar">
      <div class="progress-fill"></div>
    </div>

    <!-- Question 1 -->
    <div class="quiz-step active" data-step="1">
      <div class="step-number">Question 1 of 3</div>
      <h2 class="question-title">{{ q1_title }}</h2>
      <div class="options">
        <button type="button" class="option-btn" data-q="1" data-val="a">{{ q1_a }}</button>
        <button type="button" class="option-btn" data-q="1" data-val="b">{{ q1_b }}</button>
        <button type="button" class="option-btn" data-q="1" data-val="c">{{ q1_c }}</button>
      </div>
    </div>

    <!-- Question 2 -->
    <div class="quiz-step" data-step="2">
      <div class="step-number">Question 2 of 3</div>
      <h2 class="question-title">{{ q2_title }}</h2>
      <div class="options">
        <button type="button" class="option-btn" data-q="2" data-val="a">{{ q2_a }}</button>
        <button type="button" class="option-btn" data-q="2" data-val="b">{{ q2_b }}</button>
        <button type="button" class="option-btn" data-q="2" data-val="c">{{ q2_c }}</button>
      </div>
    </div>

    <!-- Question 3 -->
    <div class="quiz-step" data-step="3">
      <div class="step-number">Question 3 of 3</div>
      <h2 class="question-title">{{ q3_title }}</h2>
      <div class="options">
        <button type="button" class="option-btn" data-q="3" data-val="a">{{ q3_a }}</button>
        <button type="button" class="option-btn" data-q="3" data-val="b">{{ q3_b }}</button>
        <button type="button" class="option-btn" data-q="3" data-val="c">{{ q3_c }}</button>
      </div>
    </div>

    <!-- Results -->
    <div class="quiz-result" data-result="1">
      <div class="result-label">We recommend</div>
      {%- if r1_product.featured_image != blank -%}
        <img class="result-image" src="{{ r1_product.featured_image | image_url: width: 400 }}" alt="{{ r1_product.title }}" width="400">
      {%- endif -%}
      <h2 class="result-name">{{ r1_name }}</h2>
      <p class="result-desc">{{ r1_desc }}</p>
      <a href="{% if r1_product != blank %}{{ r1_product.url }}{% else %}#{% endif %}" class="result-shop-btn">{{ shop_btn_label }}</a>
      <button type="button" class="retake-btn">{{ retake_label }}</button>
    </div>
    <div class="quiz-result" data-result="2">
      <div class="result-label">We recommend</div>
      {%- if r2_product.featured_image != blank -%}
        <img class="result-image" src="{{ r2_product.featured_image | image_url: width: 400 }}" alt="{{ r2_product.title }}" width="400">
      {%- endif -%}
      <h2 class="result-name">{{ r2_name }}</h2>
      <p class="result-desc">{{ r2_desc }}</p>
      <a href="{% if r2_product != blank %}{{ r2_product.url }}{% else %}#{% endif %}" class="result-shop-btn">{{ shop_btn_label }}</a>
      <button type="button" class="retake-btn">{{ retake_label }}</button>
    </div>
    <div class="quiz-result" data-result="3">
      <div class="result-label">We recommend</div>
      {%- if r3_product.featured_image != blank -%}
        <img class="result-image" src="{{ r3_product.featured_image | image_url: width: 400 }}" alt="{{ r3_product.title }}" width="400">
      {%- endif -%}
      <h2 class="result-name">{{ r3_name }}</h2>
      <p class="result-desc">{{ r3_desc }}</p>
      <a href="{% if r3_product != blank %}{{ r3_product.url }}{% else %}#{% endif %}" class="result-shop-btn">{{ shop_btn_label }}</a>
      <button type="button" class="retake-btn">{{ retake_label }}</button>
    </div>
    <div class="quiz-result" data-result="4">
      <div class="result-label">We recommend</div>
      {%- if r4_product.featured_image != blank -%}
        <img class="result-image" src="{{ r4_product.featured_image | image_url: width: 400 }}" alt="{{ r4_product.title }}" width="400">
      {%- endif -%}
      <h2 class="result-name">{{ r4_name }}</h2>
      <p class="result-desc">{{ r4_desc }}</p>
      <a href="{% if r4_product != blank %}{{ r4_product.url }}{% else %}#{% endif %}" class="result-shop-btn">{{ shop_btn_label }}</a>
      <button type="button" class="retake-btn">{{ retake_label }}</button>
    </div>
    </div>
  </div>
</div>

<script>
  (function() {
    var answers = {};

    /*
      Scoring logic — each answer adds points toward a size:
      1 = Snack 400ml, 2 = Sandwich 800ml, 3 = Crescent 1000ml, 4 = Keeper 2000ml

      Q1: snacks=1, meal prep=2, big batches=3
      Q2: just me=0, two of us=1, whole family=2
      Q3: fridge=0, on the go=0, freezer=1

      Total 0-1 → Snack, 2 → Sandwich, 3-4 → Crescent, 5-6 → Keeper
    */
    function getResult() {
      var score = 0;
      /* Q1 */
      if (answers['1'] === 'a') score += 1;
      else if (answers['1'] === 'b') score += 2;
      else if (answers['1'] === 'c') score += 3;
      /* Q2 */
      if (answers['2'] === 'b') score += 1;
      else if (answers['2'] === 'c') score += 2;
      /* Q3 */
      if (answers['3'] === 'c') score += 1;

      if (score <= 1) return '1';
      if (score === 2) return '2';
      if (score <= 4) return '3';
      return '4';
    }

    document.addEventListener('click', function(e) {
      var quiz = e.target.closest('.naunau-quiz');
      if (!quiz) return;

      /* option click */
      var opt = e.target.closest('.option-btn');
      if (opt) {
        var q = opt.getAttribute('data-q');
        var val = opt.getAttribute('data-val');
        answers[q] = val;

        /* highlight selected */
        var step = opt.closest('.quiz-step');
        step.querySelectorAll('.option-btn').forEach(function(b) { b.classList.remove('selected'); });
        opt.classList.add('selected');

        /* advance after short delay */
        setTimeout(function() {
          var currentStep = parseInt(q);
          var progressFill = quiz.querySelector('.progress-fill');

          if (currentStep < 3) {
            /* next question */
            step.classList.remove('active');
            quiz.querySelector('[data-step="' + (currentStep + 1) + '"]').classList.add('active');
            progressFill.style.width = ((currentStep) / 3 * 100) + '%';
          } else {
            /* show result */
            step.classList.remove('active');
            progressFill.style.width = '100%';
            var resultId = getResult();
            quiz.querySelector('[data-result="' + resultId + '"]').classList.add('active');
          }
        }, 300);
        return;
      }

      /* retake */
      var retake = e.target.closest('.retake-btn');
      if (retake) {
        answers = {};
        quiz.querySelectorAll('.quiz-result').forEach(function(r) { r.classList.remove('active'); });
        quiz.querySelectorAll('.quiz-step').forEach(function(s) { s.classList.remove('active'); });
        quiz.querySelectorAll('.option-btn').forEach(function(b) { b.classList.remove('selected'); });
        quiz.querySelector('[data-step="1"]').classList.add('active');
        quiz.querySelector('.progress-fill').style.width = '0%';
      }
    });
  })();
</script>

