      "default": "#1A1A1A"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button Colour",
      "default": "#30493b"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Colour",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "NauNau Plastic Counter"
    }
  ]
}
{% endschema %}
