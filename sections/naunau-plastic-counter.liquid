{% liquid
  assign bags_per_naunau = section.settings.bags_per_naunau | default: 260
  assign heading = section.settings.heading | default: "NauNau Plastic Counter"
  assign info_text = section.settings.info_text | default: "Each NauNau replaces roughly 260 single-use bags over its lifetime"
  assign counter_label = section.settings.counter_label | default: "plastic bags replaced so far 🌍"
  assign subheading = section.settings.subheading | default: "See how much plastic you're replacing — enter your bag count"
  assign button_label = section.settings.button_label | default: "Calculate"

  assign heading_color = section.settings.heading_color | default: "#30493b"
  assign heading_size = section.settings.heading_size | default: "42px"
  assign info_color = section.settings.info_color | default: "#666666"
  assign info_size = section.settings.info_size | default: "13px"
  assign number_color = section.settings.number_color | default: "#b8ceba"
  assign number_size = section.settings.number_size | default: "80px"
  assign label_color = section.settings.label_color | default: "#b8ceba"
  assign label_size = section.settings.label_size | default: "18px"
  assign subheading_color = section.settings.subheading_color | default: "#444444"
  assign subheading_size = section.settings.subheading_size | default: "14px"
  assign block_bg = section.settings.block_bg | default: "#1A1A1A"
  assign section_bg = section.settings.section_bg | default: "#ffffff"
  assign button_bg = section.settings.button_bg | default: "#30493b"
  assign button_text_color = section.settings.button_text_color | default: "#ffffff"
%}

<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Chewy&family=Playfair+Display:ital@1&family=DM+Sans:wght@400;500;700&display=swap">

<style>
  .naunau-plastic-counter {
    padding: 60px 20px;
    text-align: center;
    width: 100%;
    background: {{ section_bg }};
  }
  .naunau-plastic-counter .counter-inner {
    max-width: 40%;
    margin: 0 auto;
  }
  .naunau-plastic-counter .section-heading {
    font-family: 'Chewy', cursive;
    font-size: {{ heading_size }};
    color: {{ heading_color }};
    margin-bottom: 8px;
  }
  .naunau-plastic-counter .info-text {
    font-family: 'DM Sans', sans-serif;
    font-size: {{ info_size }};
    color: {{ info_color }};
    margin-bottom: 28px;
    line-height: 1.5;
    white-space: nowrap;
  }
  .naunau-plastic-counter .counter-display {
    background: {{ block_bg }};
    border-radius: 20px;
    padding: 30px 30px;
    margin-bottom: 24px;
  }
  .naunau-plastic-counter .big-number {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: {{ number_size }};
    color: {{ number_color }};
    line-height: 1;
    margin-bottom: 8px;
    letter-spacing: -2px;
    transition: all 0.3s ease;
    text-align: center;
  }
  .naunau-plastic-counter .counter-label {
    font-family: 'DM Sans', sans-serif;
    font-size: {{ label_size }};
    color: {{ label_color }};
    opacity: 0.8;
    text-align: center;
  }
  .naunau-plastic-counter .subheading {
    font-family: 'DM Sans', sans-serif;
    font-size: {{ subheading_size }};
    color: {{ subheading_color }};
    margin-bottom: 20px;
    line-height: 1.5;
  }
  .naunau-plastic-counter .calc-row {
    display: flex;
    gap: 10px;
  }
  .naunau-plastic-counter .calc-input {
    flex: 1;
    background: #fff;
    border: 1px solid #ddd;
    border-radius: 10px;
    padding: 14px 16px;
    font-family: 'DM Sans', sans-serif;
    font-size: 16px;
    color: #1a1a1a;
    outline: none;
    transition: border-color 0.2s;
    -moz-appearance: textfield;
  }
  .naunau-plastic-counter .calc-input::-webkit-outer-spin-button,
  .naunau-plastic-counter .calc-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  .naunau-plastic-counter .calc-input::placeholder {
    color: #bbb;
  }
  .naunau-plastic-counter .calc-input:focus {
    border-color: {{ button_bg }};
  }
  .naunau-plastic-counter .calc-button {
    background: {{ button_bg }};
    color: {{ button_text_color }};
    border: none;
    border-radius: 10px;
    padding: 14px 28px;
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    transition: opacity 0.2s;
    white-space: nowrap;
  }
  .naunau-plastic-counter .calc-button:hover {
    opacity: 0.85;
  }
  @media (max-width: 900px) {
    .naunau-plastic-counter .counter-inner {
      max-width: 90%;
    }
  }
  @media (max-width: 600px) {
    .naunau-plastic-counter {
      padding: 40px 16px;
    }
    .naunau-plastic-counter .big-number {
      font-size: 56px;
    }
    .naunau-plastic-counter .counter-display {
      padding: 24px 20px;
      border-radius: 16px;
    }
    .naunau-plastic-counter .calc-row {
      flex-direction: column;
    }
    .naunau-plastic-counter .counter-inner {
      max-width: 100%;
    }
  }
</style>

<div class="naunau-plastic-counter">
  <div class="counter-inner">
    <h2 class="section-heading">{{ heading }}</h2>
    <p class="info-text">{{ info_text }}</p>

    <div class="counter-display">
      <div class="big-number" data-bags-per="{{ bags_per_naunau }}">0</div>
      <div class="counter-label">{{ counter_label }}</div>
    </div>

    <p class="subheading">{{ subheading }}</p>

    <div class="calc-row">
      <input
        type="number"
        class="calc-input"
        min="0"
        max="9999"
        placeholder="0"
      >
      <button type="button" class="calc-button">{{ button_label }}</button>
    </div>
  </div>
</div>

<script>
  (function() {
    function formatNumber(n) {
      return n.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ',');
    }

    function doCalculate(container) {
      var input = container.querySelector('.calc-input');
      var bigNumber = container.querySelector('.big-number');
      var bagsPerNaunau = parseInt(bigNumber.getAttribute('data-bags-per')) || 260;
      var qty = parseInt(input.value) || 0;
      bigNumber.textContent = formatNumber(qty * bagsPerNaunau);
    }

    document.addEventListener('click', function(e) {
      var btn = e.target.closest('.naunau-plastic-counter .calc-button');
      if (!btn) return;
      doCalculate(btn.closest('.naunau-plastic-counter'));
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' && e.target.matches('.naunau-plastic-counter .calc-input')) {
        e.preventDefault();
        doCalculate(e.target.closest('.naunau-plastic-counter'));
      }
    });
  })();
</script>

{% schema %}
{
  "name": "NauNau Plastic Counter",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Text Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "NauNau Plastic Counter"
    },
    {
      "type": "text",
      "id": "info_text",
      "label": "Info Text",
      "default": "Each NauNau replaces roughly 260 single-use bags over its lifetime"
    },
    {
      "type": "text",
      "id": "counter_label",
      "label": "Counter Label",
      "default": "plastic bags replaced so far 🌍"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading (above input)",
      "default": "See how much plastic you're replacing — enter your bag count"
    },
    {
      "type": "text",
      "id": "bags_per_naunau",
      "label": "Bags Per NauNau",
      "default": "260",
      "info": "Multiplier: input × this number = result"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Calculate"
    },
    {
      "type": "header",
      "content": "Heading Style"
    },
    {
      "type": "color",
