      "label": "Heading Colour",
      "default": "#30493b"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading Size",
      "options": [
        { "value": "28px", "label": "Small" },
        { "value": "36px", "label": "Medium" },
        { "value": "42px", "label": "Large" },
        { "value": "52px", "label": "Extra Large" }
      ],
      "default": "42px"
    },
    {
      "type": "header",
      "content": "Info Text Style"
    },
    {
      "type": "color",
      "id": "info_color",
      "label": "Info Text Colour",
      "default": "#666666"
    },
    {
      "type": "select",
      "id": "info_size",
      "label": "Info Text Size",
      "options": [
        { "value": "11px", "label": "Small" },
        { "value": "13px", "label": "Medium" },
        { "value": "15px", "label": "Large" },
        { "value": "18px", "label": "Extra Large" }
      ],
      "default": "13px"
    },
    {
      "type": "header",
      "content": "Number Style"
    },
    {
      "type": "color",
      "id": "number_color",
      "label": "Number Colour",
      "default": "#b8ceba"
    },
    {
      "type": "select",
      "id": "number_size",
      "label": "Number Size",
      "options": [
        { "value": "56px", "label": "Small" },
        { "value": "72px", "label": "Medium" },
        { "value": "80px", "label": "Large" },
        { "value": "96px", "label": "Extra Large" },
        { "value": "120px", "label": "Huge" }
      ],
      "default": "80px"
    },
    {
      "type": "header",
      "content": "Counter Label Style"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label Colour",
      "default": "#b8ceba"
    },
    {
      "type": "select",
      "id": "label_size",
      "label": "Label Size",
      "options": [
        { "value": "13px", "label": "Small" },
        { "value": "16px", "label": "Medium" },
        { "value": "18px", "label": "Large" },
        { "value": "22px", "label": "Extra Large" }
      ],
      "default": "18px"
    },
    {
      "type": "header",
      "content": "Subheading Style"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading Colour",
      "default": "#444444"
    },
    {
      "type": "select",
      "id": "subheading_size",
      "label": "Subheading Size",
      "options": [
        { "value": "12px", "label": "Small" },
        { "value": "14px", "label": "Medium" },
        { "value": "16px", "label": "Large" },
        { "value": "18px", "label": "Extra Large" }
      ],
      "default": "14px"
    },
    {
      "type": "header",
      "content": "Backgrounds & Button"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Section Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "block_bg",
