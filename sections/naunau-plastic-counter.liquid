{% liquid
  assign bags_per_naunau = section.settings.bags_per_naunau | default: 260
  assign counter_label = section.settings.counter_label | default: "plastic bags replaced so far 🌍"
  assign subheading = section.settings.subheading | default: "Each NauNau replaces roughly 260 single-use bags over its lifetime"
  assign button_label = section.settings.button_label | default: "Calculate"
%}

<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital@1&family=DM+Sans:wght@400;500;700&display=swap">

<style>
  .naunau-plastic-counter {
    padding: 60px 20px;
    text-align: center;
    width: 100%;
  }
  .naunau-plastic-counter .counter-inner {
    max-width: 600px;
    margin: 0 auto;
  }
  .naunau-plastic-counter .counter-display {
    background: #1A1A1A;
    border-radius: 20px;
    padding: 50px 40px 40px;
    margin-bottom: 30px;
  }
  .naunau-plastic-counter .big-number {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 96px;
    color: #b8ceba;
    line-height: 1;
    margin-bottom: 12px;
    letter-spacing: -2px;
    transition: all 0.3s ease;
  }
  .naunau-plastic-counter .counter-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 16px;
    color: #b8ceba;
    opacity: 0.8;
  }
  .naunau-plastic-counter .subheading {
    font-family: 'DM Sans', sans-serif;
    font-size: 16px;
    color: #444;
    margin-bottom: 28px;
    line-height: 1.5;
  }
  .naunau-plastic-counter .calc-row {
    display: flex;
    gap: 12px;
    max-width: 420px;
    margin: 0 auto;
  }
  .naunau-plastic-counter .calc-input {
    flex: 1;
    background: #fff;
    border: 1px solid #ddd;
    border-radius: 10px;
    padding: 16px 20px;
    font-family: 'DM Sans', sans-serif;
    font-size: 18px;
    color: #1a1a1a;
    outline: none;
    transition: border-color 0.2s;
    -moz-appearance: textfield;
  }
  .naunau-plastic-counter .calc-input::-webkit-outer-spin-button,
  .naunau-plastic-counter .calc-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  .naunau-plastic-counter .calc-input::placeholder {
    color: #bbb;
  }
  .naunau-plastic-counter .calc-input:focus {
    border-color: #30493b;
  }
  .naunau-plastic-counter .calc-button {
    background: #30493b;
    color: #fff;
    border: none;
    border-radius: 10px;
    padding: 16px 32px;
    font-family: 'DM Sans', sans-serif;
    font-size: 16px;
    font-weight: 700;
    cursor: pointer;
    transition: opacity 0.2s;
    white-space: nowrap;
  }
  .naunau-plastic-counter .calc-button:hover {
    opacity: 0.85;
  }
  @media (max-width: 600px) {
    .naunau-plastic-counter {
      padding: 40px 16px;
    }
    .naunau-plastic-counter .big-number {
      font-size: 64px;
    }
    .naunau-plastic-counter .counter-display {
      padding: 40px 24px 32px;
      border-radius: 16px;
    }
    .naunau-plastic-counter .calc-row {
      flex-direction: column;
    }
  }
</style>

<div class="naunau-plastic-counter">
  <div class="counter-inner">
    <div class="counter-display">
      <div class="big-number" data-bags-per="{{ bags_per_naunau }}">0</div>
      <div class="counter-label">{{ counter_label }}</div>
    </div>

    <p class="subheading">{{ subheading }}</p>

    <div class="calc-row">
      <input
        type="number"
        class="calc-input"
        min="0"
        max="9999"
        placeholder="0"
      >
      <button type="button" class="calc-button">{{ button_label }}</button>
    </div>
  </div>
</div>

<script>
  (function() {
    function formatNumber(n) {
      return n.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ',');
    }

    document.addEventListener('click', function(e) {
      var btn = e.target.closest('.naunau-plastic-counter .calc-button');
      if (!btn) return;
      var container = btn.closest('.naunau-plastic-counter');
      var input = container.querySelector('.calc-input');
      var bigNumber = container.querySelector('.big-number');
      var bagsPerNaunau = parseInt(bigNumber.getAttribute('data-bags-per')) || 260;
      var qty = parseInt(input.value) || 0;
      bigNumber.textContent = formatNumber(qty * bagsPerNaunau);
    });
  })();
</script>

{% schema %}
{
  "name": "NauNau Plastic Counter",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "counter_label",
      "label": "Counter Label",
      "default": "plastic bags replaced so far 🌍"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Each NauNau replaces roughly 260 single-use bags over its lifetime"
    },
    {
      "type": "text",
      "id": "bags_per_naunau",
      "label": "Bags Per NauNau",
      "default": "260",
      "info": "Multiplier: input × this number = result"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Calculate"
    }
  ],
  "presets": [
    {
      "name": "NauNau Plastic Counter"
    }
  ]
}
{% endschema %}
