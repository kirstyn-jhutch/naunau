{% liquid
  assign total_bags = section.settings.total_bags_replaced | default: 52000
  assign bags_per_naunau = section.settings.bags_per_naunau | default: 260
  assign heading = section.settings.heading | default: 'Single-Use Plastic Bags Replaced'
  assign subheading = section.settings.subheading | default: "Every NauNau replaces approximately 260 single-use plastic bags over its lifetime."
  assign input_label = section.settings.input_label | default: "How many NauNau bags do you own?"
  assign button_label = section.settings.button_label | default: "Calculate My Impact"
  assign result_label = section.settings.result_label | default: "plastic bags you've saved from landfill"
%}

<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital@1&family=DM+Sans:wght@400;500;700&display=swap">

<style>
  .naunau-plastic-counter {
    background: #1A1A1A;
    padding: 80px 20px;
    text-align: center;
    width: 100%;
  }
  .naunau-plastic-counter .counter-inner {
    max-width: 800px;
    margin: 0 auto;
  }
  .naunau-plastic-counter .total-number {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 96px;
    color: #6b8f71;
    line-height: 1;
    margin-bottom: 16px;
    letter-spacing: -2px;
  }
  .naunau-plastic-counter .counter-heading {
    font-family: 'DM Sans', sans-serif;
    font-size: 18px;
    font-weight: 500;
    color: #ffffff;
    text-transform: uppercase;
    letter-spacing: 3px;
    margin-bottom: 12px;
  }
  .naunau-plastic-counter .counter-subheading {
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    color: #999;
    max-width: 500px;
    margin: 0 auto 50px;
    line-height: 1.6;
  }
  .naunau-plastic-counter .divider {
    width: 60px;
    height: 2px;
    background: #30493b;
    margin: 0 auto 50px;
  }
  .naunau-plastic-counter .calculator-box {
    background: #222;
    border-radius: 16px;
    padding: 40px;
    max-width: 480px;
    margin: 0 auto;
  }
  .naunau-plastic-counter .calc-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    font-weight: 500;
    color: #ccc;
    margin-bottom: 16px;
    display: block;
  }
  .naunau-plastic-counter .calc-input-row {
    display: flex;
    gap: 12px;
    margin-bottom: 24px;
  }
  .naunau-plastic-counter .calc-input {
    flex: 1;
    background: #1A1A1A;
    border: 1px solid #444;
    border-radius: 8px;
    padding: 14px 18px;
    font-family: 'DM Sans', sans-serif;
    font-size: 18px;
    color: #fff;
    text-align: center;
    outline: none;
    transition: border-color 0.2s;
    -moz-appearance: textfield;
  }
  .naunau-plastic-counter .calc-input::-webkit-outer-spin-button,
  .naunau-plastic-counter .calc-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  .naunau-plastic-counter .calc-input:focus {
    border-color: #30493b;
  }
  .naunau-plastic-counter .calc-button {
    background: #30493b;
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 14px 28px;
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    transition: opacity 0.2s;
    white-space: nowrap;
  }
  .naunau-plastic-counter .calc-button:hover {
    opacity: 0.85;
  }
  .naunau-plastic-counter .result-area {
    display: none;
    margin-top: 0;
  }
  .naunau-plastic-counter .result-area.visible {
    display: block;
  }
  .naunau-plastic-counter .result-number {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 56px;
    color: #6b8f71;
    line-height: 1;
    margin-bottom: 8px;
  }
  .naunau-plastic-counter .result-text {
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    color: #999;
    letter-spacing: 1px;
  }
  @media (max-width: 600px) {
    .naunau-plastic-counter {
      padding: 50px 16px;
    }
    .naunau-plastic-counter .total-number {
      font-size: 60px;
    }
    .naunau-plastic-counter .counter-heading {
      font-size: 14px;
      letter-spacing: 2px;
    }
    .naunau-plastic-counter .calc-input-row {
      flex-direction: column;
    }
    .naunau-plastic-counter .calculator-box {
      padding: 28px 20px;
    }
    .naunau-plastic-counter .result-number {
      font-size: 40px;
    }
  }
</style>

<div class="naunau-plastic-counter">
  <div class="counter-inner">
    <div class="total-number" data-total="{{ total_bags }}">
      {{ total_bags | default: 0 }}
    </div>
    <h2 class="counter-heading">{{ heading }}</h2>
    <p class="counter-subheading">{{ subheading }}</p>

    <div class="divider"></div>

    <div class="calculator-box">
      <label class="calc-label">{{ input_label }}</label>
      <div class="calc-input-row">
        <input
          type="number"
          class="calc-input"
          min="0"
          max="9999"
          placeholder="0"
          data-bags-per="{{ bags_per_naunau }}"
        >
        <button type="button" class="calc-button">{{ button_label }}</button>
      </div>
      <div class="result-area">
        <div class="result-number">0</div>
        <div class="result-text">{{ result_label }}</div>
      </div>
    </div>
  </div>
</div>

<script>
  (function() {
    function initCounter(container) {
      var input = container.querySelector('.calc-input');
      var resultArea = container.querySelector('.result-area');
      var resultNumber = container.querySelector('.result-number');
      var bagsPerNaunau = parseInt(input.getAttribute('data-bags-per')) || 260;

      function formatNumber(n) {
        return n.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ',');
      }

      var totalEl = container.querySelector('.total-number');
      var totalRaw = parseInt(totalEl.getAttribute('data-total')) || 0;
      totalEl.textContent = formatNumber(totalRaw);

      function calculate() {
        var qty = parseInt(input.value) || 0;
        if (qty > 0) {
          var impact = qty * bagsPerNaunau;
          resultNumber.textContent = formatNumber(impact);
          resultArea.classList.add('visible');
        } else {
          resultArea.classList.remove('visible');
        }
      }

      input.addEventListener('input', calculate);
      container.querySelector('.calc-button').addEventListener('click', calculate);
    }

    document.addEventListener('input', function(e) {
      if (e.target.matches('.naunau-plastic-counter .calc-input')) {
        var container = e.target.closest('.naunau-plastic-counter');
        if (container && !container._counterInit) {
          initCounter(container);
          container._counterInit = true;
        }
        var qty = parseInt(e.target.value) || 0;
        var bagsPerNaunau = parseInt(e.target.getAttribute('data-bags-per')) || 260;
        var resultArea = container.querySelector('.result-area');
        var resultNumber = container.querySelector('.result-number');
        if (qty > 0) {
          var impact = qty * bagsPerNaunau;
          resultNumber.textContent = impact.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ',');
          resultArea.classList.add('visible');
        } else {
          resultArea.classList.remove('visible');
        }
      }
    });

    document.addEventListener('click', function(e) {
      var btn = e.target.closest('.naunau-plastic-counter .calc-button');
      if (btn) {
        var container = btn.closest('.naunau-plastic-counter');
        if (container && !container._counterInit) {
          initCounter(container);
          container._counterInit = true;
        }
      }
    });

    document.querySelectorAll('.naunau-plastic-counter').forEach(function(c) {
      if (!c._counterInit) {
        initCounter(c);
        c._counterInit = true;
      }
    });
  })();
</script>

{% schema %}
{
  "name": "NauNau Plastic Counter",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Counter Display"
    },
    {
      "type": "text",
      "id": "total_bags_replaced",
      "label": "Total Bags Replaced",
      "default": "52000",
      "info": "The big headline number shown at the top"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Single-Use Plastic Bags Replaced"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Every NauNau replaces approximately 260 single-use plastic bags over its lifetime."
    },
    {
      "type": "header",
      "content": "Calculator"
    },
    {
      "type": "text",
      "id": "bags_per_naunau",
      "label": "Bags Replaced Per NauNau",
      "default": "260",
      "info": "Multiplier used in the calculator"
    },
    {
      "type": "text",
      "id": "input_label",
      "label": "Input Label",
      "default": "How many NauNau bags do you own?"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Calculate My Impact"
    },
    {
      "type": "text",
      "id": "result_label",
      "label": "Result Label",
      "default": "plastic bags you've saved from landfill"
    }
  ],
  "presets": [
    {
      "name": "NauNau Plastic Counter"
    }
  ]
}
{% endschema %}
