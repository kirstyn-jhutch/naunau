{%- style -%}
  {{ section.settings.eyebrow_font | font_face: font_display: 'swap' }}
  {{ section.settings.heading_font_picker | font_face: font_display: 'swap' }}
  {{ section.settings.heading_font | font_face: font_display: 'swap' }}
  {{ section.settings.body_font | font_face: font_display: 'swap' }}
{%- endstyle -%}

<section id="how-it-works" class="nn-hiw" {% if section.settings.bg_image != blank %}style="background-image: url('{{ section.settings.bg_image | image_url: width: 2000 }}');background-size: cover;background-position: center;"{% endif %}>
  <div class="nn-hiw__container">
    <span class="nn-hiw__eyebrow" style="color: {{ section.settings.eyebrow_color }};font-size: {{ section.settings.eyebrow_size }}px;font-family: {{ section.settings.eyebrow_font.family }}, {{ section.settings.eyebrow_font.fallback_families }};">{{ section.settings.eyebrow }}</span>
    <h2 class="nn-hiw__heading" style="color: {{ section.settings.heading_color }};font-size: {{ section.settings.heading_size }}px;font-family: {{ section.settings.heading_font_picker.family }}, {{ section.settings.heading_font_picker.fallback_families }};">{{ section.settings.heading }}</h2>
    <div class="nn-hiw__steps">
      {%- for block in section.blocks -%}
        {%- if block.type == 'step' -%}
          <div class="nn-hiw__step {% if forloop.first %}nn-hiw__step--first{% endif %}{% if forloop.last %}nn-hiw__step--last{% endif %}" style="background: {{ block.settings.block_bg_color | default: section.settings.card_bg_color }};" {{ block.shopify_attributes }}>
            <span class="nn-hiw__step-bg-num">{{ forloop.index }}</span>
            <span class="nn-hiw__emoji" style="font-size: {{ block.settings.block_emoji_size }}px;">{{ block.settings.emoji }}</span>
            <span class="nn-hiw__step-label">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
            <h3 class="nn-hiw__step-title" style="color: {{ block.settings.block_title_color | default: section.settings.accent_color }};font-size: {{ block.settings.block_title_size }}px;">{{ block.settings.title }}</h3>
            <p class="nn-hiw__step-desc" style="color: {{ block.settings.block_text_color | default: section.settings.text_color }};font-size: {{ block.settings.block_body_size }}px;">{{ block.settings.description }}</p>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
  <div class="nn-hiw__extra">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'heading' -%}
          <div class="nn-extra-block" style="text-align: {{ block.settings.alignment }};" {{ block.shopify_attributes }}>
            <{{ block.settings.tag }} class="nn-extra-heading" style="font-size: {{ block.settings.size }}px;color: {{ block.settings.color }};">{{ block.settings.text }}</{{ block.settings.tag }}>
          </div>
        {%- when 'text' -%}
          <div class="nn-extra-block" style="text-align: {{ block.settings.alignment }};" {{ block.shopify_attributes }}>
            <div class="nn-extra-text" style="font-size: {{ block.settings.size }}px;color: {{ block.settings.color }};">{{ block.settings.content }}</div>
          </div>
        {%- when 'button' -%}
          <div class="nn-extra-block" style="text-align: {{ block.settings.alignment }};" {{ block.shopify_attributes }}>
            <a href="{{ block.settings.link }}" class="nn-extra-btn" style="background: {{ block.settings.bg_color }};color: {{ block.settings.text_color }};border-radius: {{ block.settings.radius }}px;font-size: {{ block.settings.size }}px;">{{ block.settings.text }}</a>
          </div>
        {%- when 'image' -%}
          <div class="nn-extra-block" style="text-align: {{ block.settings.alignment }};" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              <div style="display: inline-block;border-radius: {{ block.settings.radius }}px;overflow: hidden;max-width: {{ block.settings.max_width }}px;width: 100%;">
                {{ block.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', class: 'nn-extra-img' }}
              </div>
            {%- endif -%}
          </div>
        {%- when 'link' -%}
          <div class="nn-extra-block" style="text-align: {{ block.settings.alignment }};" {{ block.shopify_attributes }}>
            <a href="{{ block.settings.url }}" class="nn-extra-link" style="font-size: {{ block.settings.size }}px;color: {{ block.settings.color }};">{{ block.settings.text }}</a>
          </div>
      {%- endcase -%}
    {%- endfor -%}
  </div>
</section>

<style>
  .nn-hiw {
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 2rem {{ section.settings.padding_bottom }}px;
    font-family: {{ section.settings.body_font.family | default: 'DM Sans' }}, {{ section.settings.body_font.fallback_families | default: 'sans-serif' }};
  }
  .nn-hiw__container {
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
  }
  .nn-hiw__eyebrow {
    font-size: {{ section.settings.eyebrow_size }}px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: {{ section.settings.eyebrow_color }};
    margin-bottom: 0.5rem;
    display: block;
  }
  .nn-hiw__heading {
    font-family: {{ section.settings.heading_font.family | default: 'DM Serif Display' }}, {{ section.settings.heading_font.fallback_families | default: 'serif' }};
    font-size: {{ section.settings.heading_size }}px;
    font-weight: 400;
    color: {{ section.settings.heading_color }};
    margin: 0 0 3rem 0;
  }
  .nn-hiw__steps {
    display: flex;
    gap: {{ section.settings.step_gap }}px;
  }
  .nn-hiw__step {
    flex: 1;
    background: {{ section.settings.card_bg_color }};
    padding: 2.5rem 1.5rem 2rem;
    text-align: left;
    position: relative;
    overflow: hidden;
    transition: background 0.3s ease;
  }
  .nn-hiw__step:hover {
    background: {{ section.settings.card_hover_color }};
  }
  .nn-hiw__step--first {
    border-radius: {{ section.settings.card_radius }}px 0 0 {{ section.settings.card_radius }}px;
  }
  .nn-hiw__step--last {
    border-radius: 0 {{ section.settings.card_radius }}px {{ section.settings.card_radius }}px 0;
  }
  .nn-hiw__step-bg-num {
    position: absolute;
    bottom: -10px;
    right: 8px;
    font-family: {{ section.settings.heading_font.family | default: 'DM Serif Display' }}, {{ section.settings.heading_font.fallback_families | default: 'serif' }};
    font-size: 8rem;
    font-weight: 400;
    color: {{ section.settings.bg_number_color }};
    opacity: 0.18;
    line-height: 1;
    pointer-events: none;
    z-index: 0;
  }
  .nn-hiw__emoji {
    display: block;
    font-size: {{ section.settings.emoji_size }}px;
    margin-bottom: 1rem;
    position: relative;
    z-index: 1;
  }
  .nn-hiw__step-label {
    display: block;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: {{ section.settings.eyebrow_color }};
    margin-bottom: 0.5rem;
    position: relative;
    z-index: 1;
  }
  .nn-hiw__step-title {
    font-family: {{ section.settings.heading_font.family | default: 'DM Serif Display' }}, {{ section.settings.heading_font.fallback_families | default: 'serif' }};
    font-size: {{ section.settings.step_title_size }}px;
    font-weight: 400;
    color: {{ section.settings.accent_color }};
    margin: 0 0 0.6rem 0;
    position: relative;
    z-index: 1;
  }
  .nn-hiw__step-desc {
    font-size: {{ section.settings.body_size }}px;
    line-height: 1.6;
    color: {{ section.settings.text_color }};
    margin: 0;
    position: relative;
    z-index: 1;
  }
  .nn-hiw__extra {
    max-width: 1200px;
    margin: 0 auto;
  }
  .nn-extra-block { margin: 1.5rem 0; }
  .nn-extra-heading {
    font-family: {{ section.settings.heading_font.family | default: 'DM Serif Display' }}, {{ section.settings.heading_font.fallback_families | default: 'serif' }};
    font-weight: 400;
    margin: 0;
  }
  .nn-extra-text { line-height: 1.7; }
  .nn-extra-btn {
    display: inline-block;
    font-weight: 600;
    padding: 0.85rem 2rem;
    text-decoration: none;
    transition: opacity 0.3s ease;
  }
  .nn-extra-btn:hover { opacity: 0.85; }
  .nn-extra-img { width: 100%; display: block; }
  .nn-extra-link {
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .nn-extra-link:hover { opacity: 0.7; }

  @media (max-width: 768px) {
    .nn-hiw { padding: 3rem 1.25rem; }
    .nn-hiw__steps {
      flex-direction: column;
      gap: {{ section.settings.step_gap }}px;
    }
    .nn-hiw__step--first { border-radius: {{ section.settings.card_radius }}px {{ section.settings.card_radius }}px 0 0; }
    .nn-hiw__step--last { border-radius: 0 0 {{ section.settings.card_radius }}px {{ section.settings.card_radius }}px; }
    .nn-hiw__step { padding: 2rem 1.25rem 1.5rem; }
    .nn-hiw__step-bg-num { font-size: 5rem; }
  }
</style>

