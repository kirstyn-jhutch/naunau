<section class="nn-hiw">
  <div class="nn-hiw__container">
    <span class="nn-hiw__eyebrow">{{ section.settings.eyebrow }}</span>
    <h2 class="nn-hiw__heading">{{ section.settings.heading }}</h2>
    <div class="nn-hiw__steps">
      {%- for block in section.blocks -%}
        <div class="nn-hiw__step {% if forloop.first %}nn-hiw__step--first{% endif %}{% if forloop.last %}nn-hiw__step--last{% endif %}" {{ block.shopify_attributes }}>
          <span class="nn-hiw__step-bg-num">{{ forloop.index }}</span>
          <span class="nn-hiw__emoji">{{ block.settings.emoji }}</span>
          <span class="nn-hiw__step-label">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
          <h3 class="nn-hiw__step-title">{{ block.settings.title }}</h3>
          <p class="nn-hiw__step-desc">{{ block.settings.description }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .nn-hiw {
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 2rem {{ section.settings.padding_bottom }}px;
    font-family: 'DM Sans', sans-serif;
  }
  .nn-hiw__container {
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
  }
  .nn-hiw__eyebrow {
    font-family: 'DM Sans', sans-serif;
    font-size: {{ section.settings.eyebrow_size }}px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: {{ section.settings.eyebrow_color }};
    margin-bottom: 0.5rem;
    display: block;
  }
  .nn-hiw__heading {
    font-family: 'DM Serif Display', serif;
    font-size: {{ section.settings.heading_size }}px;
    font-weight: 400;
    color: {{ section.settings.heading_color }};
    margin: 0 0 3rem 0;
  }
  .nn-hiw__steps {
    display: flex;
    gap: {{ section.settings.step_gap }}px;
  }
  .nn-hiw__step {
    flex: 1;
    background: {{ section.settings.card_bg_color }};
    padding: 2.5rem 1.5rem 2rem;
    text-align: left;
    position: relative;
    overflow: hidden;
    transition: background 0.3s ease;
  }
  .nn-hiw__step:hover {
    background: {{ section.settings.card_hover_color }};
  }
  .nn-hiw__step--first {
    border-radius: {{ section.settings.card_radius }}px 0 0 {{ section.settings.card_radius }}px;
  }
  .nn-hiw__step--last {
    border-radius: 0 {{ section.settings.card_radius }}px {{ section.settings.card_radius }}px 0;
  }
  .nn-hiw__step-bg-num {
    position: absolute;
    bottom: -10px;
    right: 8px;
    font-family: 'DM Serif Display', serif;
    font-size: 8rem;
    font-weight: 400;
    color: {{ section.settings.bg_number_color }};
    opacity: 0.18;
    line-height: 1;
    pointer-events: none;
    z-index: 0;
  }
  .nn-hiw__emoji {
    display: block;
    font-size: {{ section.settings.emoji_size }}px;
    margin-bottom: 1rem;
    position: relative;
    z-index: 1;
  }
  .nn-hiw__step-label {
    display: block;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: {{ section.settings.eyebrow_color }};
    margin-bottom: 0.5rem;
    position: relative;
    z-index: 1;
  }
  .nn-hiw__step-title {
    font-family: 'DM Serif Display', serif;
    font-size: {{ section.settings.step_title_size }}px;
    font-weight: 400;
    color: {{ section.settings.accent_color }};
    margin: 0 0 0.6rem 0;
    position: relative;
    z-index: 1;
  }
  .nn-hiw__step-desc {
    font-family: 'DM Sans', sans-serif;
    font-size: {{ section.settings.body_size }}px;
    line-height: 1.6;
    color: {{ section.settings.text_color }};
    margin: 0;
    position: relative;
    z-index: 1;
  }

  @media (max-width: 768px) {
    .nn-hiw { padding: 3rem 1.25rem; }
    .nn-hiw__steps {
      flex-direction: column;
      gap: {{ section.settings.step_gap }}px;
    }
    .nn-hiw__step--first { border-radius: {{ section.settings.card_radius }}px {{ section.settings.card_radius }}px 0 0; }
    .nn-hiw__step--last { border-radius: 0 0 {{ section.settings.card_radius }}px {{ section.settings.card_radius }}px; }
    .nn-hiw__step { padding: 2rem 1.25rem 1.5rem; }
    .nn-hiw__step-bg-num { font-size: 5rem; }
  }
</style>

