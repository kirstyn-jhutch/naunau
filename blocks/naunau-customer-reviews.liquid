{% liquid
  assign heading = block.settings.heading | default: 'Customer Reviews'
  assign r1_stars = block.settings.r1_stars | default: 5
  assign r2_stars = block.settings.r2_stars | default: 5
  assign r3_stars = block.settings.r3_stars | default: 4
  assign r4_stars = block.settings.r4_stars | default: 5
  assign r5_stars = block.settings.r5_stars | default: 4
  assign r6_stars = block.settings.r6_stars | default: 5

  assign total = 0
  assign sum = 0
  assign star5 = 0
  assign star4 = 0
  assign star3 = 0
  assign star2 = 0
  assign star1 = 0

  if block.settings.r1_name != blank
    assign total = total | plus: 1
    assign sum = sum | plus: r1_stars
    if r1_stars == 5
      assign star5 = star5 | plus: 1
    elsif r1_stars == 4
      assign star4 = star4 | plus: 1
    elsif r1_stars == 3
      assign star3 = star3 | plus: 1
    elsif r1_stars == 2
      assign star2 = star2 | plus: 1
    elsif r1_stars == 1
      assign star1 = star1 | plus: 1
    endif
  endif

  if block.settings.r2_name != blank
    assign total = total | plus: 1
    assign sum = sum | plus: r2_stars
    if r2_stars == 5
      assign star5 = star5 | plus: 1
    elsif r2_stars == 4
      assign star4 = star4 | plus: 1
    elsif r2_stars == 3
      assign star3 = star3 | plus: 1
    elsif r2_stars == 2
      assign star2 = star2 | plus: 1
    elsif r2_stars == 1
      assign star1 = star1 | plus: 1
    endif
  endif

  if block.settings.r3_name != blank
    assign total = total | plus: 1
    assign sum = sum | plus: r3_stars
    if r3_stars == 5
      assign star5 = star5 | plus: 1
    elsif r3_stars == 4
      assign star4 = star4 | plus: 1
    elsif r3_stars == 3
      assign star3 = star3 | plus: 1
    elsif r3_stars == 2
      assign star2 = star2 | plus: 1
    elsif r3_stars == 1
      assign star1 = star1 | plus: 1
    endif
  endif

  if block.settings.r4_name != blank
    assign total = total | plus: 1
    assign sum = sum | plus: r4_stars
    if r4_stars == 5
      assign star5 = star5 | plus: 1
    elsif r4_stars == 4
      assign star4 = star4 | plus: 1
    elsif r4_stars == 3
      assign star3 = star3 | plus: 1
    elsif r4_stars == 2
      assign star2 = star2 | plus: 1
    elsif r4_stars == 1
      assign star1 = star1 | plus: 1
    endif
  endif

  if block.settings.r5_name != blank
    assign total = total | plus: 1
    assign sum = sum | plus: r5_stars
    if r5_stars == 5
      assign star5 = star5 | plus: 1
    elsif r5_stars == 4
      assign star4 = star4 | plus: 1
    elsif r5_stars == 3
      assign star3 = star3 | plus: 1
    elsif r5_stars == 2
      assign star2 = star2 | plus: 1
    elsif r5_stars == 1
      assign star1 = star1 | plus: 1
    endif
  endif

  if block.settings.r6_name != blank
    assign total = total | plus: 1
    assign sum = sum | plus: r6_stars
    if r6_stars == 5
      assign star5 = star5 | plus: 1
    elsif r6_stars == 4
      assign star4 = star4 | plus: 1
    elsif r6_stars == 3
      assign star3 = star3 | plus: 1
    elsif r6_stars == 2
      assign star2 = star2 | plus: 1
    elsif r6_stars == 1
      assign star1 = star1 | plus: 1
    endif
  endif

  if total > 0
    assign avg_x10 = sum | times: 10 | divided_by: total
    assign avg_whole = avg_x10 | divided_by: 10
    assign avg_decimal = avg_x10 | modulo: 10

    assign pct5 = star5 | times: 100 | divided_by: total
    assign pct4 = star4 | times: 100 | divided_by: total
    assign pct3 = star3 | times: 100 | divided_by: total
    assign pct2 = star2 | times: 100 | divided_by: total
    assign pct1 = star1 | times: 100 | divided_by: total
  else
    assign avg_whole = 0
    assign avg_decimal = 0
    assign pct5 = 0
    assign pct4 = 0
    assign pct3 = 0
    assign pct2 = 0
    assign pct1 = 0
  endif
%}

<div class="naunau-reviews-block" {{ block.shopify_attributes }}>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Chewy&display=swap">

  <style>
    .naunau-reviews-block {
      width: 100%;
      max-width: 900px;
      margin: 0 auto;
      padding: 40px 20px;
    }
    .naunau-reviews-block .reviews-heading {
      font-family: 'Chewy', cursive;
      font-size: 28px;
      text-align: center;
      margin-bottom: 30px;
      color: #1a1a1a;
    }
    .naunau-reviews-block .reviews-summary {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 40px;
      background: #fff;
      border: 1px solid #e0e0e0;
      border-radius: 12px;
      padding: 30px;
      margin: 0 auto 30px;
      max-width: 700px;
    }
    .naunau-reviews-block .summary-score {
      text-align: center;
      min-width: 120px;
    }
    .naunau-reviews-block .score-number {
      font-family: 'Chewy', cursive;
      font-size: 48px;
      color: #1a1a1a;
      line-height: 1;
    }
    .naunau-reviews-block .score-stars {
      color: #f0a500;
      font-size: 20px;
      margin: 8px 0 4px;
    }
    .naunau-reviews-block .score-count {
      font-size: 14px;
      color: #666;
    }
    .naunau-reviews-block .summary-bars {
      flex: 1;
      max-width: 400px;
    }
    .naunau-reviews-block .bar-row {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 6px;
    }
    .naunau-reviews-block .bar-label {
      font-size: 13px;
      color: #666;
      min-width: 45px;
      text-align: right;
    }
    .naunau-reviews-block .bar-track {
      flex: 1;
      height: 10px;
      background: #f0f0f0;
      border-radius: 5px;
      overflow: hidden;
    }
    .naunau-reviews-block .bar-fill {
      height: 100%;
      background: #f0a500;
      border-radius: 5px;
      transition: width 0.3s ease;
    }
    .naunau-reviews-block .bar-count {
      font-size: 13px;
      color: #666;
      min-width: 20px;
    }
    .naunau-reviews-block .reviews-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
      max-width: 900px;
      margin: 0 auto;
    }
    .naunau-reviews-block .review-card {
      background: #fff;
      border: 1px solid #e0e0e0;
      border-radius: 12px;
      padding: 24px;
    }
    .naunau-reviews-block .review-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 8px;
    }
    .naunau-reviews-block .reviewer-name {
      font-weight: 600;
      font-size: 15px;
      color: #1a1a1a;
    }
    .naunau-reviews-block .review-date {
      font-size: 13px;
      color: #999;
    }
    .naunau-reviews-block .review-stars {
      color: #f0a500;
      font-size: 16px;
      margin-bottom: 6px;
    }
    .naunau-reviews-block .verified-badge {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      font-size: 12px;
      color: #30493b;
      font-weight: 500;
      margin-bottom: 10px;
    }
    .naunau-reviews-block .verified-badge svg {
      width: 14px;
      height: 14px;
      fill: #30493b;
    }
    .naunau-reviews-block .review-text {
      font-size: 14px;
      line-height: 1.6;
      color: #444;
    }
    @media (max-width: 768px) {
      .naunau-reviews-block .reviews-summary {
        flex-direction: column;
        gap: 20px;
        text-align: center;
      }
      .naunau-reviews-block .reviews-grid {
        grid-template-columns: 1fr;
      }
      .naunau-reviews-block .bar-label {
        text-align: left;
      }
    }
  </style>

  <h2 class="reviews-heading">{{ heading }}</h2>

  {% if total > 0 %}
    <div class="reviews-summary">
      <div class="summary-score">
        <div class="score-number">{{ avg_whole }}.{{ avg_decimal }}</div>
        <div class="score-stars">
          {%- for i in (1..5) -%}
            {%- if i <= avg_whole -%}&#9733;{%- else -%}&#9734;{%- endif -%}
          {%- endfor -%}
        </div>
        <div class="score-count">
          Based on {% if total == 1 %}{{ total }} review{% else %}{{ total }} reviews{% endif %}
        </div>
      </div>
      <div class="summary-bars">
        <div class="bar-row">
          <span class="bar-label">5 star</span>
          <div class="bar-track"><div class="bar-fill" style="width: {{ pct5 }}%"></div></div>
          <span class="bar-count">{{ star5 }}</span>
        </div>
        <div class="bar-row">
          <span class="bar-label">4 star</span>
          <div class="bar-track"><div class="bar-fill" style="width: {{ pct4 }}%"></div></div>
          <span class="bar-count">{{ star4 }}</span>
        </div>
        <div class="bar-row">
          <span class="bar-label">3 star</span>
          <div class="bar-track"><div class="bar-fill" style="width: {{ pct3 }}%"></div></div>
          <span class="bar-count">{{ star3 }}</span>
        </div>
        <div class="bar-row">
          <span class="bar-label">2 star</span>
          <div class="bar-track"><div class="bar-fill" style="width: {{ pct2 }}%"></div></div>
          <span class="bar-count">{{ star2 }}</span>
        </div>
        <div class="bar-row">
          <span class="bar-label">1 star</span>
          <div class="bar-track"><div class="bar-fill" style="width: {{ pct1 }}%"></div></div>
          <span class="bar-count">{{ star1 }}</span>
        </div>
      </div>
    </div>

    <div class="reviews-grid">
      {%- if block.settings.r1_name != blank -%}
        <div class="review-card">
          <div class="review-header">
            <span class="reviewer-name">{{ block.settings.r1_name }}</span>
            <span class="review-date">{{ block.settings.r1_date }}</span>
          </div>
          <div class="review-stars">{%- for i in (1..5) -%}{%- if i <= r1_stars -%}&#9733;{%- else -%}&#9734;{%- endif -%}{%- endfor -%}</div>
          {%- if block.settings.r1_verified -%}
            <div class="verified-badge">
              <svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/></svg>
              Verified Purchase
            </div>
          {%- endif -%}
          <div class="review-text">{{ block.settings.r1_text }}</div>
        </div>
      {%- endif -%}

      {%- if block.settings.r2_name != blank -%}
        <div class="review-card">
          <div class="review-header">
            <span class="reviewer-name">{{ block.settings.r2_name }}</span>
            <span class="review-date">{{ block.settings.r2_date }}</span>
          </div>
          <div class="review-stars">{%- for i in (1..5) -%}{%- if i <= r2_stars -%}&#9733;{%- else -%}&#9734;{%- endif -%}{%- endfor -%}</div>
          {%- if block.settings.r2_verified -%}
            <div class="verified-badge">
              <svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/></svg>
              Verified Purchase
            </div>
          {%- endif -%}
          <div class="review-text">{{ block.settings.r2_text }}</div>
        </div>
      {%- endif -%}

      {%- if block.settings.r3_name != blank -%}
        <div class="review-card">
          <div class="review-header">
            <span class="reviewer-name">{{ block.settings.r3_name }}</span>
            <span class="review-date">{{ block.settings.r3_date }}</span>
          </div>
          <div class="review-stars">{%- for i in (1..5) -%}{%- if i <= r3_stars -%}&#9733;{%- else -%}&#9734;{%- endif -%}{%- endfor -%}</div>
          {%- if block.settings.r3_verified -%}
            <div class="verified-badge">
              <svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/></svg>
              Verified Purchase
            </div>
          {%- endif -%}
          <div class="review-text">{{ block.settings.r3_text }}</div>
        </div>
      {%- endif -%}

      {%- if block.settings.r4_name != blank -%}
        <div class="review-card">
          <div class="review-header">
            <span class="reviewer-name">{{ block.settings.r4_name }}</span>
            <span class="review-date">{{ block.settings.r4_date }}</span>
          </div>
          <div class="review-stars">{%- for i in (1..5) -%}{%- if i <= r4_stars -%}&#9733;{%- else -%}&#9734;{%- endif -%}{%- endfor -%}</div>
          {%- if block.settings.r4_verified -%}
            <div class="verified-badge">
              <svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/></svg>
              Verified Purchase
            </div>
          {%- endif -%}
          <div class="review-text">{{ block.settings.r4_text }}</div>
        </div>
      {%- endif -%}

      {%- if block.settings.r5_name != blank -%}
        <div class="review-card">
          <div class="review-header">
            <span class="reviewer-name">{{ block.settings.r5_name }}</span>
            <span class="review-date">{{ block.settings.r5_date }}</span>
          </div>
          <div class="review-stars">{%- for i in (1..5) -%}{%- if i <= r5_stars -%}&#9733;{%- else -%}&#9734;{%- endif -%}{%- endfor -%}</div>
          {%- if block.settings.r5_verified -%}
            <div class="verified-badge">
              <svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/></svg>
              Verified Purchase
            </div>
          {%- endif -%}
          <div class="review-text">{{ block.settings.r5_text }}</div>
        </div>
      {%- endif -%}

      {%- if block.settings.r6_name != blank -%}
        <div class="review-card">
          <div class="review-header">
            <span class="reviewer-name">{{ block.settings.r6_name }}</span>
            <span class="review-date">{{ block.settings.r6_date }}</span>
          </div>
          <div class="review-stars">{%- for i in (1..5) -%}{%- if i <= r6_stars -%}&#9733;{%- else -%}&#9734;{%- endif -%}{%- endfor -%}</div>
          {%- if block.settings.r6_verified -%}
            <div class="verified-badge">
              <svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/></svg>
              Verified Purchase
            </div>
          {%- endif -%}
          <div class="review-text">{{ block.settings.r6_text }}</div>
        </div>
      {%- endif -%}
    </div>
  {% endif %}
</div>

