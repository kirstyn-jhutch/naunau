          color: {{ block.settings.label_color }};
          text-transform: uppercase;
          letter-spacing: 0.08em;
          font-weight: 500;
          display: block;
          margin-bottom: 4px;
        ">{{ block.settings.stat5_label }}</span>
        <span class="nn-specs__value" style="
          font-size: {{ block.settings.value_size }}px;
