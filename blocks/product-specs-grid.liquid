{% liquid
  assign product_resource = closest.product
  if request.visual_preview_mode and product_resource == blank
    assign product_resource = collections.all.products.first
  endif
%}

<div class="nn-specs spacing-style" style="{% render 'spacing-style', settings: block.settings %}" {{ block.shopify_attributes }}>
  {%- if block.settings.heading != blank -%}
    <h3 class="nn-specs__heading" style="
      font-family: 'Chewy', cursive;
      font-weight: normal;
      font-size: {{ block.settings.heading_size }}px;
      color: {{ block.settings.heading_color }};
      margin-bottom: 16px;
    ">{{ block.settings.heading }}</h3>
  {%- endif -%}

  <div class="nn-specs__grid" style="
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.gap }}px;
  ">
    {%- if block.settings.stat1_label != blank -%}
      <div class="nn-specs__cell" style="
        background: {{ block.settings.cell_bg }};
        border: 1px solid {{ block.settings.cell_border }};
        border-radius: {{ block.settings.cell_radius }}px;
        padding: {{ block.settings.cell_padding }}px;
      ">
        <span class="nn-specs__label" style="
          font-size: {{ block.settings.label_size }}px;
          color: {{ block.settings.label_color }};
          text-transform: uppercase;
          letter-spacing: 0.08em;
          font-weight: 500;
          display: block;
          margin-bottom: 4px;
        ">{{ block.settings.stat1_label }}</span>
        <span class="nn-specs__value" style="
          font-size: {{ block.settings.value_size }}px;
          color: {{ block.settings.value_color }};
          font-weight: 700;
        ">{{ block.settings.stat1_value }}</span>
        <span class="nn-specs__unit" style="
          font-size: {{ block.settings.unit_size }}px;
          color: {{ block.settings.label_color }};
          font-weight: 400;
        ">{{ block.settings.stat1_unit }}</span>
      </div>
    {%- endif -%}

    {%- if block.settings.stat2_label != blank -%}
      <div class="nn-specs__cell" style="
        background: {{ block.settings.cell_bg }};
        border: 1px solid {{ block.settings.cell_border }};
        border-radius: {{ block.settings.cell_radius }}px;
        padding: {{ block.settings.cell_padding }}px;
      ">
        <span class="nn-specs__label" style="
          font-size: {{ block.settings.label_size }}px;
          color: {{ block.settings.label_color }};
          text-transform: uppercase;
          letter-spacing: 0.08em;
          font-weight: 500;
          display: block;
          margin-bottom: 4px;
        ">{{ block.settings.stat2_label }}</span>
        <span class="nn-specs__value" style="
          font-size: {{ block.settings.value_size }}px;
          color: {{ block.settings.value_color }};
          font-weight: 700;
        ">{{ block.settings.stat2_value }}</span>
        <span class="nn-specs__unit" style="
          font-size: {{ block.settings.unit_size }}px;
          color: {{ block.settings.label_color }};
          font-weight: 400;
        ">{{ block.settings.stat2_unit }}</span>
      </div>
    {%- endif -%}

    {%- if block.settings.stat3_label != blank -%}
      <div class="nn-specs__cell" style="
        background: {{ block.settings.cell_bg }};
        border: 1px solid {{ block.settings.cell_border }};
